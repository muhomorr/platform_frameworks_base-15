<!--
  This file contains a list of preinstalled packages that are exempt from App Lock.
  Apps included in this list will not be allowed to have app lock enabled, and will not present
  any App Lock enablement flows.

  To add a package to this exemption list, use the following format within the <config> tag:
  <app-lock-exempt package="your.package.name" />
  Replace "your.package.name" with the actual package name of the app to be exempted.

  Keep the list alphabetically sorted for ease of use.
-->
<config>
    <app-lock-exempt package="com.android.camera2" />
    <app-lock-exempt package="com.android.contacts" />
    <app-lock-exempt package="com.android.deskclock" />
    <app-lock-exempt package="com.android.settings" />
</config>

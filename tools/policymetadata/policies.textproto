policy_metadata {
  identifier {
    field_name: "AUTO_TIME_ZONE"
    class_name: "PolicyIdentifier"
    package_name: "android.app.admin"
  }
  type {
    class_name: "Integer"
    package_name: "java.lang"
  }
  documentation: "Policy that controls whether the device\'s time zone is set automatically, e.g. obtained from\nnetwork or location."
  type_specific_metadata {
    enum_metadata {
      int_def_name: "android.app.admin.PolicyIdentifier.AutoTimeZoneValue"
      documentation: "Possible values {@link #AUTO_TIME_ZONE}\n\n@hide"
      values {
        field_name {
          field_name: "AUTO_TIME_ZONE_USER_CHOICE"
          class_name: "PolicyIdentifier"
          package_name: "android.app.admin"
        }
        documentation: "The user can choose whether the device\'s time zone is set automatically or not. "
      }
      values {
        field_name {
          field_name: "AUTO_TIME_ZONE_DISABLED_UNENFORCED"
          class_name: "PolicyIdentifier"
          package_name: "android.app.admin"
        }
        int_value: 1
        documentation: "The admin has disabled automatic time zone detection. This is not enforced and the user can\nstill enable it. Use {@link UserManager#DISALLOW_CONFIG_DATE_TIME} to enforce the policy."
      }
      values {
        field_name {
          field_name: "AUTO_TIME_ZONE_ENABLED_UNENFORCED"
          class_name: "PolicyIdentifier"
          package_name: "android.app.admin"
        }
        int_value: 2
        documentation: "The admin has enabled the time zone to be automatically obtained from the network. This is\nnot enforced and the user can still disable it. Use {@link\nUserManager#DISALLOW_CONFIG_DATE_TIME} to enforce the policy."
      }
      values {
        field_name {
          field_name: "AUTO_TIME_ZONE_DISABLED"
          class_name: "PolicyIdentifier"
          package_name: "android.app.admin"
        }
        int_value: 3
        documentation: "The admin has disabled automatic time zone detection. This is enforced and the user cannot\nenable it."
      }
      values {
        field_name {
          field_name: "AUTO_TIME_ZONE_ENABLED"
          class_name: "PolicyIdentifier"
          package_name: "android.app.admin"
        }
        int_value: 4
        documentation: "The admin has enabled the time zone to be automatically obtained from the network. This is\nenforced and the user cannot disable it."
      }
      resolution_mechanism {
        custom: true
      }
    }
  }
  allowed_scopes: POLICY_SCOPE_DEVICE
  affected_resource: RESOURCE_DEVICE_WIDE
  required_permission: "android.permission.SET_TIME_ZONE"
  required_cross_user_permission: "android.permission.MANAGE_DEVICE_POLICY_ACROSS_USERS"

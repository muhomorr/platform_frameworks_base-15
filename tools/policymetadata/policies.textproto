policy_metadata {
  identifier {
    field_name: "LOCKSCREEN_MESSAGE"
    class_name: "PolicyIdentifier"
    package_name: "android.app.admin"
  }
  type {
    class_name: "String"
    package_name: "java.lang"
  }
  documentation: "Policy that sets a custom message to be shown on the lock screen. This message is displayed\non the device screen when locked, and is useful for a lost or stolen device.\n\n<p>The message set using this method overrides any owner information manually set by the user\nand prevents the user from further changing it.\n\n<p>If the message is {@code null} then the device owner info is cleared and the user owner\ninfo is shown on the lock screen if it is set.\n\n<p>If the message contains only whitespaces then the message on the lock screen will be blank\nand the user will not be allowed to change it.\n\n<p>If the message needs to be localized, it is the responsibility of the {@link\nDeviceAdminReceiver} to listen to the {@link Intent#ACTION_LOCALE_CHANGED} broadcast and set\na new version of this string accordingly."
  type_specific_metadata {
    string_metadata {
    }
  }
  allowed_scopes: POLICY_SCOPE_DEVICE
  affected_resource: RESOURCE_DEVICE_WIDE
  required_permission: "android.permission.MANAGE_DEVICE_POLICY_LOCKSCREEN_MESSAGE"
  required_cross_user_permission: "android.permission.MANAGE_DEVICE_POLICY_ACROSS_USERS"
  allowed_dpc_types: DPC_TYPE_DEVICE_OWNER
  allowed_dpc_types: DPC_TYPE_MANAGED_PROFILE_OWNER_OF_ORGANIZATION_OWNED_DEVICE
}

    <string name="app_label" msgid="1092971641119916701">"Վիրտուալ սարքերի կառավարիչ"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Թույլատրե՞լ &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; հավելվածին էկրանի ավտոմատացումը"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Թույլատրե՞լ &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; հավելվածին օգտագործել էկրանի ավտոմատացումը &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt; հավելվածի հետ"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Այս հավելվածը կկարողանա փոխազդել այլ հավելվածների՝ էկրանին ցուցադրվող բովանդակության հետ՝ օգնելու ձեզ առաջադրանքներ կատարել, նույնիսկ երբ հավելվածները ֆոնային ռեժիմում են աշխատում"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"Միայն այս անգամ"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"Չթույլատրել"</string>
    <string name="request_computer_control_access_dialog_button_always_allow" msgid="1551784758130170359">"Միշտ թույլատրել"</string>
    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> հավելվածն օգտագործում է <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g> հավելվածը"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Առաջադրանքի կատարման ընթացքը դիտելու համար բացեք <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g> հավելվածը։<xliff:g id="EMPTY_LINE">

</xliff:g>Եթե հիմա կանգնեցնեք առաջադրանքը, ձեր առաջընթացը կարող է չպահպանվել։ Վերագործարկելու համար բացեք <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g> հավելվածը։"</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"Կանգնեցնել առաջադրանքը և բացել հավելվածը"</string>

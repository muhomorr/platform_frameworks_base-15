    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"&lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; экранды автоматтандыруды қолдансын ба?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"&lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; қолданбасы &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt; экранын автоматтандырсын ба?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Бұл қолданба тапсырмаларды орындауға көмектесу үшін басқа қолданбалардың экран контентін көре алады және олармен әрекеттесе алады. Бұл әрекет қолданбалар фондық режимде болған кезде де орындалады."</string>

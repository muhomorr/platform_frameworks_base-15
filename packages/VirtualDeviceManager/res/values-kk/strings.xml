    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g> қолданбасын пайдаланып жатыр"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Тапсырманың орындалу барысын көру үшін <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g> қолданбасын ашыңыз.<xliff:g id="EMPTY_LINE">


    <string name="app_label" msgid="1092971641119916701">"Мениджър на виртуалните устройства"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Да се разреши ли на &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; да използва автоматизирането на екрана?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Да се разреши ли на &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; да използва автоматизирането на екрана с(ъс) &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Това приложение ще може да вижда съдържанието на екрана на други приложения и да взаимодейства с него, за да ви помага да изпълнявате задачи дори когато приложенията са на заден план"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"Само този път"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"Забраняване"</string>
    <string name="request_computer_control_access_dialog_button_always_allow" msgid="1551784758130170359">"Разрешаване винаги"</string>
    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> използва <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g>"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"За да видите напредъка на задачата, отворете приложението <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>.<xliff:g id="EMPTY_LINE">

</xliff:g>Ако спрете задачата сега, може да загубите напредъка си. За да рестартирате, отворете приложението <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g>."</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"Спиране на задачата и отваряне на приложението"</string>
    <string name="automated_app_launch_warning_dialog_wait" msgid="3472782366270857170">"Затваряне"</string>

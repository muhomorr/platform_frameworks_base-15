    <string name="app_label" msgid="1092971641119916701">"مدیر دستگاه مجازی"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"‏به &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; اجازه استفاده از خودکارسازی صفحه‌نمایش می‌دهید؟"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"‏به &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; اجازه استفاده از خودکارسازی صفحه‌نمایش با &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt; می‌دهید؟"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"این برنامه می‌تواند محتوای صفحه برنامه‌های دیگر را ببیند و با آن‌ها تعامل داشته باشد تا به شما در انجام تکالیف کمک کند، حتی زمانی که برنامه‌ها در پس‌زمینه هستند"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"فقط این بار"</string>

    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> از <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g> استفاده می‌کند"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"برای مشاهده پیشرفت تکلیف، برنامه <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g> را باز کنید.<xliff:g id="EMPTY_LINE">

</xliff:g>اگر تکلیف را اکنون متوقف کنید، ممکن است پیشرفت خود را ازدست بدهید. برای بازراه‌اندازی، برنامه <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g> را باز کنید."</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"تکلیف متوقف شود و برنامه باز شود"</string>

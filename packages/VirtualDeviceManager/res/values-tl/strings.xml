    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"Ginagamit ng <xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> ang <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g>"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Para tingnan ang pag-usad ng gawain, buksan ang <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g> app.<xliff:g id="EMPTY_LINE">


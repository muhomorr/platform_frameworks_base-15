    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"Ihinto ang gawain at buksan ang app"</string>
    <string name="automated_app_launch_warning_dialog_wait" msgid="3472782366270857170">"Isara"</string>

    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Payagan ang &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; na gumamit ng screen automation?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Payagan ang &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; na gumamit ng screen automation sa &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Magagawa ng app na ito na makita ang at makipag-interact sa content ng screen ng iba pang app para tulungan kang kumumpleto ng mga gawain, kahit na nasa background ang mga app"</string>

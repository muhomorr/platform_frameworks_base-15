    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Para ver el progreso de la tarea, abre la app de <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>.<xliff:g id="EMPTY_LINE">


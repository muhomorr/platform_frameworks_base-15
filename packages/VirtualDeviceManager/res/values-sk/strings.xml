<resources xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="app_label" msgid="1092971641119916701">"Správca virtuálnych zariadení"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Chcete povoliť aplikácii &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; používať automatizáciu obrazovky?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Chcete povoliť aplikácii &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; používať automatizáciu obrazovky s aplikáciou &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Táto aplikácia bude môcť čítať obsah obrazovky iných aplikácií a interagovať s ním, aby vám pomáhala dokončovať úlohy, a to aj vtedy, keď budú dané aplikácie spustené na pozadí"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"Iba tentokrát"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"Nepovoliť"</string>
    <string name="request_computer_control_access_dialog_button_always_allow" msgid="1551784758130170359">"Vždy povoliť"</string>
    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> používa <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g>"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Ak si chcete zobraziť postup v úlohe, otvorte aplikáciu <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>.<xliff:g id="EMPTY_LINE">

</xliff:g>Ak úlohu teraz zastavíte, môžete prísť o postup. Ak chcete reštartovať, otvorte aplikáciu <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g>."</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"Zastaviť úlohu a otvoriť aplikáciu"</string>
    <string name="automated_app_launch_warning_dialog_wait" msgid="3472782366270857170">"Zavrieť"</string>

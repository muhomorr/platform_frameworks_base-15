    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Izinkan &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; menggunakan otomatisasi layar?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Izinkan &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; menggunakan otomatisasi layar dengan &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Aplikasi ini akan dapat melihat dan berinteraksi dengan konten layar aplikasi lain untuk membantu Anda menyelesaikan tugas, bahkan saat aplikasi tersebut berjalan di latar belakang"</string>

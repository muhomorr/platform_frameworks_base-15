    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"‏לתת לאפליקציה &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; הרשאה להשתמש באינטראקציה אוטומטית עם התוכן במסך?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"‏לתת לאפליקציה &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; הרשאה להשתמש באינטראקציה אוטומטית עם התוכן במסך עם &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"האפליקציה הזו תוכל לראות את תוכן המסך של אפליקציות אחרות ולקיים איתו אינטראקציה כדי לעזור לך במשימות, גם כשהאפליקציות פועלות ברקע"</string>

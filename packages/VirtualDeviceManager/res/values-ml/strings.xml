    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"&lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt; എന്നതിനൊപ്പം സ്ക്രീൻ ഓട്ടോമേഷൻ ഉപയോഗിക്കാൻ &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; എന്നതിനെ അനുവദിക്കണോ?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"ആപ്പുകൾ പശ്ചാത്തലത്തിലാണെങ്കിൽ പോലും, ടാസ്‌ക്കുകൾ പൂർത്തിയാക്കാൻ നിങ്ങളെ സഹായിക്കുന്നതിന് മറ്റ് ആപ്പുകളുടെ സ്ക്രീൻ ഉള്ളടക്കം കാണാനും അവയുമായി ഇടപഴകാനും ഈ ആപ്പിന് കഴിയും"</string>

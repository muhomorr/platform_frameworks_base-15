    <string name="app_label" msgid="1092971641119916701">"ምናባዊ የመሣሪያ አስተዳዳሪ"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"&lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; የማያ ገጽ አውቶሜሽን እንዲጠቀም ይፈቀድ?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"&lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; ከ &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt; ጋር የማያ ገጽ አውቶሜሽን እንዲጠቀም ይፈቀድ?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"ይህ መተግበሪያ መተግበሪያዎቹ በዳራ ውስጥ ቢሆኑም እንኳን እርስዎ ተግባሮችን እንዲያጠናቅቁ ለማገዝ የሌሎች መተግበሪያዎችን የማያ ገጽ ይዘት ማየት እና ከእነሱ ጋር መስተጋብር መፍጠር ይችላል"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"አሁን ብቻ"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"አትፍቀድ"</string>
    <string name="request_computer_control_access_dialog_button_always_allow" msgid="1551784758130170359">"ሁልጊዜ ፍቀድ"</string>
    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g>ን እየተጠቀመ ነው"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"የተግባር ሂደትን ለማየት፣ የ<xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g> መተግበሪያን ይክፈቱ።<xliff:g id="EMPTY_LINE">

</xliff:g>ተግባሩን አሁን ካቆሙት፣ ሂደትዎን ሊያጡ ይችላሉ። ዳግም ለማስጀመር፣ የ<xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g> መተግበሪያን ይክፈቱ።"</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"ተግባርን አቁም እና መተግበሪያን ክፈት"</string>
    <string name="automated_app_launch_warning_dialog_wait" msgid="3472782366270857170">"ዝጋ"</string>
</resources>

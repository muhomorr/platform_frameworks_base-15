    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Permiți ca &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; să folosească automatizarea ecranului?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Permiți ca &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; să folosească automatizarea ecranului în &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Aplicația va putea să vadă conținutul de pe ecran din alte aplicații și să interacționeze cu acesta pentru a te ajuta să finalizezi activități, chiar și atunci când aplicațiile sunt în fundal."</string>

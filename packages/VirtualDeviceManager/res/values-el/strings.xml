    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Να επιτρέπεται στο &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; η χρήση του αυτοματισμού οθόνης;"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Να επιτρέπεται στο &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; η χρήση του αυτοματισμού οθόνης με &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;;"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Αυτή η εφαρμογή θα μπορεί να βλέπει και να αλληλεπιδρά με το περιεχόμενο της οθόνης άλλων εφαρμογών, για να σας βοηθά να ολοκληρώνετε εργασίες, ακόμα και όταν οι εφαρμογές βρίσκονται στο παρασκήνιο"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"Μόνο αυτή τη φορά"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"Να μην επιτρέπεται"</string>

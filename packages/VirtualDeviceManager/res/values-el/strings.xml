    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"Το <xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> χρησιμοποιεί την εφαρμογή <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g>"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Για να δείτε την πρόοδο της εργασίας, ανοίξτε την εφαρμογή <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>.<xliff:g id="EMPTY_LINE">

</xliff:g>Αν διακόψετε την εργασία τώρα, μπορεί να χάσετε την πρόοδό σας. Για επανεκκίνηση, ανοίξτε την εφαρμογή <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g>."</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"Διακοπή εργασίας και άνοιγμα εφαρμογής"</string>

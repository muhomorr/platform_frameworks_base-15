<resources xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="app_label" msgid="1092971641119916701">"仮想デバイス マネージャー"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"&lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; にスクリーン オートメーションの使用を許可しますか？"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"&lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; に &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt; でのスクリーン オートメーションの使用を許可しますか？"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"このアプリで、他のアプリの画面のコンテンツを参照して操作し、タスクを完了できるようになります（アプリがバックグラウンドで動作している場合でも同様です）"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"今回のみ"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"許可しない"</string>
    <string name="request_computer_control_access_dialog_button_always_allow" msgid="1551784758130170359">"常に許可"</string>
    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> が <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g> を使用します"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"タスクの進行状況を確認するには、<xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g> アプリを開いてください。<xliff:g id="EMPTY_LINE">

</xliff:g>今タスクを停止すると、進行状況が失われる可能性があります。再起動するには、<xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g> アプリを開いてください。"</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"タスクを停止してアプリを開く"</string>
    <string name="automated_app_launch_warning_dialog_wait" msgid="3472782366270857170">"閉じる"</string>
</resources>

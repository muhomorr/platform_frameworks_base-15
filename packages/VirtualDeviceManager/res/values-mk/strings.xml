<resources xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="app_label" msgid="1092971641119916701">"Виртуелен управувач со уреди"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Да се дозволи &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; да користи автоматизација на екранот?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Да се дозволи &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; да користи автоматизација на екранот со &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Апликацијава ќе може да ги гледа и да стапува во интеракција со содржините на екранот на другите апликации за да ви помага да ги завршувате задачите, дури и кога апликациите се во заднина"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"Само овој пат"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"Не дозволувај"</string>
    <string name="request_computer_control_access_dialog_button_always_allow" msgid="1551784758130170359">"Секогаш дозволувај"</string>
    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> користи <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g>"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"За да го видите напредокот на задачата, отворете ја апликацијата <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>.<xliff:g id="EMPTY_LINE">

</xliff:g>Ако ја сопрете задачата сега, може да го изгубите напредокот. За да рестартирате, отворете ја апликацијата <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g>."</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"Сопри ја задачата и отвори ја апликацијата"</string>
    <string name="automated_app_launch_warning_dialog_wait" msgid="3472782366270857170">"Затвори"</string>

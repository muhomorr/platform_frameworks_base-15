    xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="app_label" msgid="1092971641119916701">"අතථ්‍ය උපාංග කළමනාකරු"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"&lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; හට තිර ස්වයංකරණය භාවිත කිරීමට ඉඩ දෙන්න ද?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"&lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; හට &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt; සමග තිර ස්වයංකරණය භාවිත කිරීමට ඉඩ දෙන්න ද?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"යෙදුම් පසුබිමේ ඇති විට පවා, කාර්යයන් සම්පූර්ණ කිරීමට ඔබට උපකාර කිරීම සඳහා මෙම යෙදුමට අනෙකුත් යෙදුම්වල තිර අන්තර්ගතය දැක බලා ඒවා සමඟ අන්තර්ක්‍රියා කිරීමට හැකි වනු ඇත."</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"මෙම වතාවේ පමණි"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"ඉඩ නොදෙන්න"</string>
    <string name="request_computer_control_access_dialog_button_always_allow" msgid="1551784758130170359">"සැම විට ම ඉඩ දෙන්න"</string>
    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g> භාවිතා කරයි"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"කාර්ය ප්‍රගතිය බැලීමට, <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g> යෙදුම විවෘත කරන්න.<xliff:g id="EMPTY_LINE">

</xliff:g>ඔබ දැන් කාර්යය නැවැත්වුවහොත්, ඔබට ඔබේ ප්‍රගතිය අහිමි විය හැක. යළි ඇරඹීමට, <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g> යෙදුම විවෘත කරන්න."</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"කාර්යය නවත්වන්න සහ යෙදුම විවෘත කරන්න"</string>
    <string name="automated_app_launch_warning_dialog_wait" msgid="3472782366270857170">"වසන්න"</string>
</resources>

    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"「<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>」正在使用「<xliff:g id="TARGET_APP_NAME">%2$s</xliff:g>」"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"如要查看工作進度，請開啟「<xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>」應用程式。<xliff:g id="EMPTY_LINE">


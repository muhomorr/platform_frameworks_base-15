    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"要允許「<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>」&lt;strong&gt;&lt;/strong&gt;使用螢幕自動化功能嗎？"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"要允許「<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>」使用螢幕自動化功能操作「<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>」嗎？"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"這個應用程式將可查看其他應用程式的畫面，並與當中的內容互動，協助你完成工作，即使是在背景執行的應用程式也一樣"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"僅允許這一次"</string>

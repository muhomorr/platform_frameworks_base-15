    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"ٹاسک کی پیشرفت دیکھنے کے لیے، <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g> ایپ کھولیں۔<xliff:g id="EMPTY_LINE">


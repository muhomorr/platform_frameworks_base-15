    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Autoriser &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; à utiliser l\'automat. d\'écran?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Autoriser &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; autom. écran : &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Cette appli pourra voir le contenu de l\'écran d\'autres applis et interagir avec celui-ci pour vous aider à accomplir des tâches, même lorsque les applis sont en arrière-plan"</string>

    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Pour afficher la progression de la tâche, ouvrez l\'appli <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>.<xliff:g id="EMPTY_LINE">


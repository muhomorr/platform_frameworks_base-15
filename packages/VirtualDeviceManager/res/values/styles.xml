<resources>
    <!-- START REQUEST COMPUTER CONTROL ACCESS DIALOG -->

    <style name="RequestComputerControlAccessDialogScrollView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:background">@color/settingslib_materialColorSurfaceContainerHigh</item>
    </style>

    <style name="RequestComputerControlAccessDialogContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
    </style>

    <style name="RequestComputerControlAccessDialogAgentIcon">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="RequestComputerControlAccessDialogTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.HeadlineSmall</item>
    </style>

    <style name="RequestComputerControlAccessDialogDescription">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_small4</item>
        <item name="android:gravity">start</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.BodyMedium</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="RequestComputerControlAccessDialogButton"
           parent="@android:style/Widget.DeviceDefault.Button.Borderless.Colored">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/settingslib_expressive_space_none</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_small1</item>
        <item name="android:minHeight">@dimen/settingslib_expressive_space_medium3</item>
        <item name="android:background">@drawable/settingslib_expressive_button_background_filled</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.LabelLarge.Emphasized</item>
        <item name="android:textColor">@color/settingslib_materialColorOnPrimary</item>
    </style>

    <!-- END REQUEST COMPUTER CONTROL ACCESS DIALOG -->

    <!-- START AUTOMATED APP LAUNCH WARNING ACTIVITY DIALOG -->

    <style name="AutomatedAppLaunchWarningDialogScrollView" parent="@style/RequestComputerControlAccessDialogScrollView">
    </style>

    <style name="AutomatedAppLaunchWarningDialogContent" parent="@style/RequestComputerControlAccessDialogContent" >
    </style>

    <style name="AutomatedAppLaunchWarningDialogAgentIcon" parent="@style/RequestComputerControlAccessDialogAgentIcon"  >
    </style>

    <style name="AutomatedAppLaunchWarningDialogTitle" parent="@style/RequestComputerControlAccessDialogTitle" >
    </style>

    <style name="AutomatedAppLaunchWarningDialogDescription" parent="@style/RequestComputerControlAccessDialogDescription">
    </style>

    <style name="AutomatedAppLaunchWarningDialogWaitButton" parent="@style/RequestComputerControlAccessDialogButton">
    </style>

    <style name="AutomatedAppLaunchWarningDialogStopButton" parent="@style/RequestComputerControlAccessDialogButton">
        <item name="android:textColor">@color/settingslib_materialColorPrimary</item>
        <item name="android:background">@drawable/settingslib_expressive_button_background_outline</item>
        <item name="backgroundTint">@color/settingslib_materialColorOutlineVariant</item>
    </style>

    <!-- END AUTOMATED APP LAUNCH WARNING ACTIVITY DIALOG -->

</resources>

<resources xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="app_label" msgid="1092971641119916701">"Upravitelj navideznih naprav"</string>
    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Ali aplikaciji &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; dovolite uporabo avtomatizacije zaslona?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Ali aplikaciji &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; dovolite uporabo avtomatizacije zaslona z aplikacijo &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Ta aplikacija si bo lahko ogledala vsebino zaslona drugih aplikacij in komunicirala z njo, da vam bo pomagala dokončati opravila, tudi ko so aplikacije v ozadju"</string>
    <string name="request_computer_control_access_dialog_button_allow" msgid="6210271960695301518">"Samo tokrat"</string>
    <string name="request_computer_control_access_dialog_button_dont_allow" msgid="4793579155406896411">"Ne dovoli"</string>
    <string name="request_computer_control_access_dialog_button_always_allow" msgid="1551784758130170359">"Vedno dovoli"</string>
    <string name="automated_app_launch_warning_dialog_title" msgid="5210938311581044737">"<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g> uporablja aplikacijo <xliff:g id="TARGET_APP_NAME">%2$s</xliff:g>"</string>
    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Če si želite ogledati napredek pri opravilu, odprite aplikacijo <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>.<xliff:g id="EMPTY_LINE">

</xliff:g>Če zdaj zaustavite opravilo, lahko izgubite vse, kar je bilo narejenega. Če želite znova zagnati, odprite aplikacijo <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g>."</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"Zaustavi opravilo in odpri aplikacijo"</string>
    <string name="automated_app_launch_warning_dialog_wait" msgid="3472782366270857170">"Zapri"</string>

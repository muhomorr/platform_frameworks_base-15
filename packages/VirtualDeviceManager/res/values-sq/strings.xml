    <string name="request_computer_control_access_dialog_title" msgid="1970509993635617382">"Të lejohet që &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; të përdorë automatizimin e ekranit?"</string>
    <string name="request_computer_control_access_per_app_consent_dialog_title" msgid="8118885324223570680">"Të lejohet që &lt;strong&gt;<xliff:g id="AGENT_APP_NAME">%1$s</xliff:g>&lt;/strong&gt; të përdorë automatizimin e ekranit me &lt;strong&gt;<xliff:g id="AUTOMATABLE_APP_NAME">%2$s</xliff:g>&lt;/strong&gt;?"</string>
    <string name="request_computer_control_access_dialog_description" msgid="3423347516805473691">"Ky aplikacion do të jetë në gjendje të shikojë dhe të ndërveprojë me përmbajtjet e ekranit të aplikacioneve të tjera për të të ndihmuar të përfundosh detyrat, edhe kur aplikacionet janë në sfond"</string>

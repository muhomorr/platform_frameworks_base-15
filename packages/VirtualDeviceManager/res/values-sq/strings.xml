    <string name="automated_app_launch_warning_dialog_description" msgid="5372128583106771831">"Për të parë progresin e detyrës, hap aplikacionin <xliff:g id="AGENT_APP_NAME_0">%1$s</xliff:g>.<xliff:g id="EMPTY_LINE">

</xliff:g>Nëse e ndalon detyrën tani, mund të humbasësh progresin tënd. Për ta rinisur, hap aplikacionin <xliff:g id="AGENT_APP_NAME_1">%1$s</xliff:g>."</string>
    <string name="automated_app_launch_warning_dialog_stop" msgid="5255022618671675595">"Ndalo detyrën dhe hap aplikacionin"</string>

    <string name="permission_app_streaming_summary" msgid="4114223538437344105">"आपके डिवाइसों पर फ़ोन की स्क्रीन शेयर करना. इसमें, स्क्रीन पर दिखने वाले ऐप्लिकेशन भी शामिल हैं. आपके डिवाइस, फ़ोन की स्क्रीन पर दिखने वाले हर कॉन्टेंट को ऐक्सेस कर सकेंगे. जैसे, ऑडियो, फ़ोटो, क्रेडिट/डेबिट कार्ड की जानकारी, पासवर्ड, और मैसेज. ये डिवाइस, फ़ोन लॉक होने पर भी कॉन्टेंट ऐक्सेस कर पाएंगे.&lt;br/&gt;&lt;br/&gt;आपके डिवाइसों से माइक्रोफ़ोन, कैमरा, और अन्य सेंसर डेटा आपके फ़ोन पर भेजना. इसमें इंटरैक्शन से जुड़ा डेटा भी शामिल है, जैसे कि टच जेस्चर और माउस क्लिक."</string>
    <string name="permission_create_virtual_device_summary" msgid="3570256456647725172">"&lt;strong&gt;<xliff:g id="DEVICE_NAME">%3$s</xliff:g>&lt;/strong&gt; से <xliff:g id="DEVICE_TYPE">%2$s</xliff:g> पर माइक्रोफ़ोन, कैमरा, और अन्य सेंसर डेटा स्ट्रीम करें."</string>
    <string name="permission_add_mirror_display_summary" msgid="1385423940454941534">"अपने <xliff:g id="DEVICE_TYPE_0">%2$s</xliff:g> की स्क्रीन को &lt;strong&gt;<xliff:g id="DEVICE_NAME">%3$s</xliff:g>&lt;/strong&gt; पर रिकॉर्ड, कास्ट या शेयर करें.&lt;br/&gt;&lt;br/&gt;<xliff:g id="APP_NAME">%1$s</xliff:g> के पास आपके <xliff:g id="DEVICE_TYPE_1">%2$s</xliff:g> पर दिखने या चलने वाले हर मीडिया का ऐक्सेस होगा. जैसे, ऑडियो, फ़ोटो, क्रेडिट/डेबिट कार्ड की जानकारी, पासवर्ड, और मैसेज."</string>
    <string name="permission_add_trusted_display_summary" msgid="7399955172055281447">"<xliff:g id="DEVICE_TYPE_0">%2$s</xliff:g> पर मौजूद ऐप्लिकेशन को &lt;strong&gt;<xliff:g id="DEVICE_NAME_1">%3$s</xliff:g>&lt;/strong&gt; पर स्ट्रीम करें.&lt;br/&gt;&lt;br/&gt;<xliff:g id="APP_NAME">%1$s</xliff:g> के पास आपके <xliff:g id="DEVICE_NAME_2">%3$s</xliff:g> पर दिखने या चलने वाले हर मीडिया का ऐक्सेस होगा. जैसे, ऑडियो, फ़ोटो, क्रेडिट/डेबिट कार्ड की जानकारी, पासवर्ड, और मैसेज. यह ऐक्सेस तब भी रहेगा, जब आपका <xliff:g id="DEVICE_TYPE_3">%2$s</xliff:g> लॉक हो."</string>
    <string name="permission_media_routing_control_summary" msgid="2714631092321412250">"उपलब्ध डिवाइसों की लिस्ट देखें. साथ ही, कंट्रोल करें कि कौनसा डिवाइस, स्ट्रीम कर सकता है या दूसरे ऐप्लिकेशन से ऑडियो या वीडियो कास्ट कर सकता है"</string>

    <string name="permission_add_trusted_display_summary" msgid="7399955172055281447">"РђЈОЕОЎОЊОЋОе ОЕОю ОћОљОцОюОЎОДОдОЎОЋОф ОъОћ<xliff:g id="DEVICE_TYPE_0">%2$s</xliff:g> ОљОю &lt;strong&gt;<xliff:g id="DEVICE_NAME_1">%3$s</xliff:g>&lt;/strong&gt;.&lt;br/&gt;&lt;br/&gt;ОюОљОцОюОЎОДОдОЎОћ <xliff:g id="APP_NAME">%1$s</xliff:g> ОфОћОЎОћ ОњОЎОЕОћ ОюОЏОю ОъОћ ОЕОъОЋОдОњ ОљОЋ ОъОЋОцОбОю ОЉ-<xliff:g id="DEVICE_NAME_2">%3$s</xliff:g>, ОЏОЋОюОю ОљОЋОЊОЎОЋ, ОфОъОЋОаОЋОф, ОцОеОўОЎ ОфОЕОюОЋОЮ, ОАОЎОАОъОљОЋОф ОЋОћОЋОЊОбОЋОф, ОњОЮ ОЏОЕОћ<xliff:g id="DEVICE_TYPE_3">%2$s</xliff:g> ОаОбОЋОю."</string>

        </aapt:attr>
    </target>
    <target android:name="mask">
        <!-- custom slash -->
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="200"
                    android:interpolator="@anim/ease"
                    android:propertyName="pathData"
                    android:startOffset="0"
                    android:valueFrom="@string/path_bluetooth_diagonal_mask_off"
                    android:valueTo="@string/path_bluetooth_diagonal_mask_on"
                    android:valueType="pathType" />
            </set>
        </aapt:attr>
    </target>
    <target android:name="slash_path">
        <!-- custom slash -->
        <aapt:attr name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:duration="190"
                    android:propertyName="strokeWidth"
                    android:startOffset="0"
                    android:valueFrom="2.45"
                    android:valueTo="2.45" />
                <objectAnimator
                    android:duration="10"
                    android:propertyName="strokeWidth"
                    android:startOffset="190"
                    android:valueFrom="2.45"
                    android:valueTo="0" />
                <objectAnimator
                    android:duration="200"
                    android:interpolator="@anim/ease"
                    android:propertyName="pathData"
                    android:startOffset="0"
                    android:valueFrom="@string/path_bluetooth_slash_on"
                    android:valueTo="@string/path_bluetooth_slash_off"
                    android:valueType="pathType" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>

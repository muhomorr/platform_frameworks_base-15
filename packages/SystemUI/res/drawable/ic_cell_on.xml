<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/vd_cell">
    <!-- TODO(b/479241590): The size of vd_cell is based off an existing mobile data off icon
         with slash, but results in the icon being too visually small when the slash is gone.
         Workaround this for now by manually increasing the size of the on icon. -->
    <target android:name="root_group">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="0"
                    android:propertyName="translateX"
                    android:valueFrom="-20"
                    android:valueTo="-21.5" />
                <objectAnimator
                    android:duration="0"
                    android:propertyName="scaleX"
                    android:valueFrom="0.8169"
                    android:valueTo="1.1" />
                <objectAnimator
                    android:duration="0"
                    android:propertyName="scaleY"
                    android:valueFrom="0.8169"
                    android:valueTo="1.1" />
            </set>
        </aapt:attr>
    </target>
    <target android:name="top_arrow_resize">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="60"
                    android:interpolator="@anim/overshoot"
                    android:propertyName="translateY"
                    android:startOffset="0"
                    android:valueFrom="16.3"
                    android:valueTo="16.3" />
                <objectAnimator
                    android:duration="300"
                    android:interpolator="@anim/overshoot"
                    android:propertyName="translateY"
                    android:startOffset="60"
                    android:valueFrom="16.3"
                    android:valueTo="17.3" />
            </set>
        </aapt:attr>
    </target>
    <target android:name="bottom_arrow_resize">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="60"
                    android:interpolator="@anim/overshoot"
                    android:propertyName="translateY"
                    android:startOffset="0"
                    android:valueFrom="18.3"
                    android:valueTo="18.3" />
                <objectAnimator
                    android:duration="300"
                    android:interpolator="@anim/overshoot"
                    android:propertyName="translateY"
                    android:startOffset="60"
                    android:valueFrom="18.3"
                    android:valueTo="17.3" />
            </set>
        </aapt:attr>
    </target>

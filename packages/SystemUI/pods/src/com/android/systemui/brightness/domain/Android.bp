package {
    default_applicable_licenses: ["frameworks_base_packages_SystemUI_license"],
}

java_library {
    name: "com.android.systemui.brightness.domain-api",
    srcs: [
        "model/*.kt",
        "interactor/*.kt",
    ],
    defaults: [
        "SystemUI_pod_defaults_api",
    ],
    static_libs: [
        "kotlinx_coroutines",
        "androidx.annotation_annotation",
        "SettingsLibDisplayUtils",
        "com.android.systemui.brightness.data-api",
        "com.android.systemui.util.policy-api",
    ],
}

java_library {
    name: "com.android.systemui.brightness.domain-impl",
    srcs: [
        "model/impl/*.kt",
        "interactor/impl/*.kt",
    ],
    static_libs: [
        "kotlinx_coroutines",
        "SystemUISharedLib",
        "com.android.systemui.brightness.domain-api",
        "com.android.systemui.brightness.shared-api",
        "com.android.systemui.util.policy-api",
    ],
    defaults: [
        "SystemUI_pod_defaults_impl",
    ],
}

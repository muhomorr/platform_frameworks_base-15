package {
    default_applicable_licenses: ["frameworks_base_packages_SystemUI_license"],
}

java_library {
    name: "com.android.systemui.util.settings_api",
    defaults: ["sysui_api"],
    libs: [
        "//frameworks/libs/systemui:tracinglib-platform",
        "SystemUICommon",
        "SystemUISharedLib",
        "androidx.annotation_annotation",
        "kotlinx_coroutines_android",
    ],
}

java_library {
    name: "com.android.systemui.util.settings_main",
    defaults: ["sysui_main"],
    static_libs: [
        "com.android.systemui.util.settings_api",
        "kotlinx_coroutines_android",
    ],
}

java_library {
    name: "com.android.systemui.util.settings_dagger",
    defaults: ["sysui_dagger"],
    static_libs: [
        "com.android.systemui.util.settings_main",
    ],
}

package {
    default_applicable_licenses: ["frameworks_base_packages_SystemUI_license"],
    default_visibility: [":__subpackages__"],
}

android_library {
    name: "com.android.systemui.statusbar.chips.ui_api",
    defaults: ["sysui_api"],
    manifest: "AndroidManifest.xml",
    static_libs: ["androidx.compose.runtime_runtime"],
    libs: [
        // go/keep-sorted start
        "PlatformComposeCore",
        "SystemUI-res",
        "androidx.compose.ui_ui",
        "com.android.systemui.common.shared.model_api",
        "com.android.systemui.flags_api",
        "com.android.systemui.util.time_api",
        // go/keep-sorted end
    ],
}

android_library {
    name: "com.android.systemui.statusbar.chips.ui_testlib",
    defaults: ["sysui_testlib"],
    static_libs: [
        // go/keep-sorted start
        "SystemUI-res",
        "com.android.systemui.common.shared.model_api",
        "com.android.systemui.flags_api",
        "com.android.systemui.statusbar.chips.ui_api",
        "com.android.systemui.util.time_api",
        "flag-junit",
        "platform-parametric-runner-lib",
        "platform-test-annotations",
        "testables",
        // go/keep-sorted end
    ],
}

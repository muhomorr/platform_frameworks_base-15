package {
    default_applicable_licenses: ["frameworks_base_packages_SystemUI_license"],
}

java_library {
    name: "com.android.systemui.notifications.intelligence.rules.ui_api",
    defaults: ["sysui_api"],
    static_libs: [
        "androidx.compose.runtime_runtime",
    ],
    libs: [
        "androidx.compose.foundation_foundation",
        "com.android.systemui.lifecycle_api",
        "com.android.systemui.notifications.intelligence.rules_api",
    ],
}

java_library {
    name: "com.android.systemui.notifications.intelligence.rules.ui_main",
    defaults: ["sysui_main"],
    visibility: [
        "//frameworks/base/packages/SystemUI/pods/bundle/phone",
        "//vendor:__subpackages__",
    ],
    static_libs: [
        "com.android.systemui.lifecycle_api",
        "com.android.systemui.notifications.intelligence.rules_api",
        "com.android.systemui.notifications.intelligence.rules.ui_api",
        "PlatformComposeCore",
        "androidx.compose.foundation_foundation",
        "androidx.compose.foundation_foundation-layout",
        "androidx.compose.material3_material3",
        "androidx.compose.material_material-icons-core",
        "androidx.compose.runtime_runtime",
    ],
}

java_library {
    name: "com.android.systemui.notifications.intelligence.rules.ui_dagger",
    defaults: ["sysui_dagger"],
    static_libs: [
        "com.android.systemui.notifications.intelligence.rules.ui_main",
    ],
}

filegroup {
    name: "com.android.systemui.notifications.intelligence.rules.ui_fixtureFiles",
    defaults: ["sysui_fixtureFiles"],
}

    <string name="cannot_install_app_blocked_summary" msgid="2082063650842897085">"&lt;p&gt;Ova aplikacija je blokirana. Da se vaš uređaj i podaci zaštite, mogu se instalirati samo aplikacije potvrđenih programera.&lt;/p&gt; &lt;a href=https://g.co/android/developer&gt;Saznajte više o potvrdi programera&lt;/a&gt;"</string>
    <string name="cannot_update_app_blocked_summary" msgid="7607734844900187499">"&lt;p&gt;Ova aplikacija nije ažurirana. Da se vaš uređaj i podaci zaštite, mogu se instalirati samo ažuriranja potvrđenih programera.&lt;/p&gt; &lt;a href=https://g.co/android/developer&gt;Saznajte više o potvrdi programera&lt;/a&gt;"</string>
    <string name="cannot_install_verification_no_internet_summary" msgid="7298957699553589600">"&lt;p&gt;Ova aplikacija nije instalirana. Aplikacije nepotvrđenih programera su možda nesigurne.&lt;/p&gt; &lt;p&gt;Potrebna je internetska veza za potvrdu programera aplikacije. Provjerite vezu, a zatim ponovo pokušajte instalirati. &lt;/p&gt; &lt;a href=https://g.co/android/developer&gt;Saznajte više o potvrdi programera&lt;/a&gt;"</string>
    <string name="cannot_update_verification_no_internet_summary" msgid="8094414928318316598">"&lt;p&gt;Ova aplikacija nije ažurirana. Ažuriranja nepotvrđenih programera su možda nesigurna.&lt;/p&gt; &lt;p&gt;Potrebna je internetska veza za potvrdu programera aplikacije. Provjerite vezu, a zatim ponovo pokušajte ažurirati. &lt;/p&gt; &lt;a href=https://g.co/android/developer&gt;Saznajte više o potvrdi programera&lt;/a&gt;"</string>
    <string name="cannot_install_verification_unavailable_summary" msgid="3830073638843524892">"&lt;p&gt;Došlo je do problema s potvrdom programera aplikacije. Aplikacije nepotvrđenih programera su možda nesigurne, pa se aplikacija nije instalirala.&lt;/p&gt; &lt;a href=https://g.co/android/developer&gt;Saznajte više o potvrdi programera&lt;/a&gt;"</string>
    <string name="cannot_update_verification_unavailable_summary" msgid="342184955548504019">"&lt;p&gt;Došlo je do problema s potvrdom programera aplikacije. Ažuriranja nepotvrđenih programera su možda nesigurna, pa se aplikacija nije ažurirala.&lt;/p&gt; &lt;a href=https://g.co/android/developer&gt;Saznajte više o potvrdi programera&lt;/a&gt;"</string>
    <string name="cannot_install_verification_unavailable_fail_closed_summary" msgid="3552780111383069051">"&lt;p&gt;Ova aplikacija je blokirana jer je došlo do problema s potvrdom programera. Da se vaš uređaj i podaci zaštite, mogu se instalirati samo aplikacije potvrđenih programera.&lt;/p&gt; &lt;a href=https://g.co/android/developer&gt;Saznajte više o potvrdi programera&lt;/a&gt;"</string>
    <string name="cannot_update_verification_unavailable_fail_closed_summary" msgid="353457015429601377">"&lt;p&gt;Ova aplikacija nije ažurirana jer je došlo do problema s potvrdom programera. Da se vaš uređaj i podaci zaštite, mogu se instalirati samo ažuriranja potvrđenih programera.&lt;/p&gt; &lt;a href=https://g.co/android/developer&gt;Saznajte više o potvrdi programera&lt;/a&gt;"</string>
    <string name="more_details_expanded_install_summary" msgid="3545896392881608712">"Ako instalirate bez potvrde, imajte na umu da će aplikacije nepotvrđenih programera možda izložiti vaš uređaj i podatke riziku."</string>

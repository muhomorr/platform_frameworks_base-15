<keyboard-glyph-map xmlns:androidprv="http://schemas.android.com/apk/prv/res/android">
    <key-glyph
        androidprv:keycode="KEYCODE_BUTTON_A"
        androidprv:glyphDrawable="@drawable/default_game_controller_down_button"
        androidprv:displayName="@string/default_game_controller_down_button"/>
    <key-glyph
        androidprv:keycode="KEYCODE_BUTTON_B"
        androidprv:glyphDrawable="@drawable/default_game_controller_right_button"
        androidprv:displayName="@string/default_game_controller_right_button"/>
    <key-glyph
        androidprv:keycode="KEYCODE_BUTTON_Y"
        androidprv:glyphDrawable="@drawable/default_game_controller_up_button"
        androidprv:displayName="@string/default_game_controller_up_button"/>
    <key-glyph
        androidprv:keycode="KEYCODE_BUTTON_X"
        androidprv:glyphDrawable="@drawable/default_game_controller_left_button"
        androidprv:displayName="@string/default_game_controller_left_button"/>
</keyboard-glyph-map>
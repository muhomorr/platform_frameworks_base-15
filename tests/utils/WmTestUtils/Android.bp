package {
    // See: http://go/android-license-faq
    // A large-scale-change added 'default_applicable_licenses' to import
    // all of the 'license_kinds' from "frameworks_base_license"
    // to get the below license kinds:
    //   SPDX-license-identifier-Apache-2.0
    default_team: "trendy_team_windowing_animations_transitions",
    default_applicable_licenses: ["frameworks_base_license"],
}

java_library {
    name: "WmTestUtils",
    // When extending visibility, consider updating the tests path in
    // frameworks/base/tests/utils/WmTestUtils/TEST_MAPPING
    visibility: [
        "//frameworks/base/libs/WindowManager/Shell/tests/unittest",
        "//frameworks/base/libs/WindowManager/Shell/multivalentTests",
        "//frameworks/base/tests/VirtualDeviceTests/services",
        "//frameworks/base/services/tests/wmtests",
        "//packages/services/Car/tests/CarServiceUnitTest",
        "//packages/services/Car/libs/car-wm-shell-lib/tests/unittest",
    ],
    srcs: [
        "src/**/*.java",
        "src/**/*.kt",
    ],
    static_libs: [
        "mockito-kotlin2",
        "truth",
    ],
}

package {
    default_team: "trendy_team_input_framework",
    default_applicable_licenses: ["Android-Apache-2.0"],
}

cc_library_shared {
    name: "libinputtests_jni",
    host_supported: true,
    srcs: [
        "inputtests_jni.cpp",
    ],
    defaults: [
        "inputflinger_defaults",
    ],
    header_libs: [
        "libhwui_internal_headers",
    ],
    shared_libs: [
        "inputtests_aidl-ndk",
        "libbinder_ndk",
        "libinput",
        "liblog",
        "libutils",
    ],
    target: {
        host: {
            sanitize: {
                // The host JVMs are not built with address sanitizer (ASan) enabled;
                // as a result, they cannot load shared libraries with ASan enabled.
                // Explicitly disable ASan for the host variant of this library.
                address: false,
            },
        },
    },
}

aidl_interface {
    name: "inputtests_aidl",
    srcs: ["com/android/test/input/IInputTests.aidl"],
    unstable: true,
    host_supported: true,
}

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@android:style/Theme.Material.Wallpaper.NoTitleBar">

    <Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?android:attr/actionBarSize"
        android:background="?android:attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@android:style/ThemeOverlay.Material.Dark.ActionBar"
        android:navigationIcon="?android:attr/homeAsUpIndicator"
        android:title="Comp Shaders" />

    <!-- Area for the SurfaceControl to float over (logically) -->
    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:layout_above="@id/controls" />

    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#80000000"
        android:gravity="center_vertical">

        <Spinner
            android:id="@+id/effect_spinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:entries="@array/comp_shader_effects" />

        <Switch
            android:id="@+id/target_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Behind"
            android:paddingStart="16dp"
            android:textColor="@android:color/white" />

    </LinearLayout>

</RelativeLayout>

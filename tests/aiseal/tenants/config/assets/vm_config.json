{
  "version": 1,
  "os": {
    "name": "microdroid"
  },
  "tenants": [
    {
      "package": "apk",
      "name": "android.aiseal.tests.odim",
      "min_version": {ODIM_VERSION},
      "expected_authority": {
          "dev-keys": "{ODIM_EXPECTED_AUTHORITY}",
          "test-keys": "{ODIM_EXPECTED_AUTHORITY}",
          "release-keys": "{ODIM_EXPECTED_AUTHORITY}"
      },
      "task": {
          "type": "microdroid_launcher",
          "command": "libtest_aiseal_odim_payload.so"
      }
    }
  ],
  "export_tombstones": false,
  "enable_authfs": false,
  "hugepages": true,
  "dm_default_key": true
}

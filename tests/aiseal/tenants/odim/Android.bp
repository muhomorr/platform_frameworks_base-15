package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

aidl_interface {
    name: "odim_aidl_interface",
    srcs: ["aidl/**/*.aidl"],
    unstable: true,
    local_include_dir: "aidl",
    backend: {
        java: {
            enabled: true,
        },
        rust: {
            enabled: true,
        },
    },
}

rust_ffi {
    name: "libtest_aiseal_odim_payload",
    crate_name: "test_aiseal_odim_payload",
    srcs: ["native/main.rs"],
    edition: "2021",
    prefer_rlib: true,
    defaults: ["avf_build_flags_rust"],
    rustlibs: [
        "odim_aidl_interface-rust",
        "libandroid_logger",
        "libanyhow",
        "libbinder_rs",
        "liblog_rust",
        "libvm_payload_rs",
    ],
}

android_test_helper_app {
    name: "AiSealTestHelperAppOdim",
    srcs: ["java/**/*.java"],
    platform_apis: true,
    certificate: "platform",
    static_libs: [
        "androidx.annotation_annotation",
        "odim_aidl_interface-java",
    ],
    sdk_version: "system_current",
    jni_libs: ["libtest_aiseal_odim_payload"],
    jni_uses_platform_apis: true,
    use_embedded_native_libs: true,
    compile_multilib: "first",
}

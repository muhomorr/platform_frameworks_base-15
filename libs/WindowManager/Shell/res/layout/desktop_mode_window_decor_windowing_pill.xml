<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:androidprv="http://schemas.android.com/apk/prv/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageButton
        android:id="@+id/fullscreen_button"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:contentDescription="@string/fullscreen_text"
        android:src="@drawable/desktop_mode_ic_handle_menu_fullscreen"
        android:tint="@androidprv:color/materialColorOnSurface"
        android:tooltipText="@string/fullscreen_text"
        style="@style/DesktopModeHandleMenuWindowingButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/split_screen_button"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread"/>

    <ImageButton
        android:id="@+id/split_screen_button"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:contentDescription="@string/split_screen_text"
        android:src="@drawable/desktop_mode_ic_handle_menu_splitscreen"
        android:tint="@androidprv:color/materialColorOnSurface"
        android:tooltipText="@string/split_screen_text"
        style="@style/DesktopModeHandleMenuWindowingButton"
        app:layout_constraintStart_toEndOf="@id/fullscreen_button"
        app:layout_constraintEnd_toStartOf="@id/floating_button"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread"/>

    <ImageButton
        android:id="@+id/floating_button"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:contentDescription="@string/float_button_text"
        android:src="@drawable/desktop_mode_ic_handle_menu_floating"
        android:tint="@androidprv:color/materialColorOnSurface"
        android:tooltipText="@string/float_button_text"
        style="@style/DesktopModeHandleMenuWindowingButton"
        app:layout_constraintStart_toEndOf="@id/split_screen_button"
        app:layout_constraintEnd_toStartOf="@id/desktop_button"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread"/>

    <ImageButton
        android:id="@+id/desktop_button"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:contentDescription="@string/desktop_text"
        android:src="@drawable/desktop_mode_ic_handle_menu_desktop"
        android:tint="@androidprv:color/materialColorOnSurface"
        android:tooltipText="@string/desktop_text"
        style="@style/DesktopModeHandleMenuWindowingButton"
        app:layout_constraintStart_toEndOf="@id/floating_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread"/>
</androidx.constraintlayout.widget.ConstraintLayout>

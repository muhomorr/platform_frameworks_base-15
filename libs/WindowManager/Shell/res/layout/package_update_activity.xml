<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:focusable="true"
    android:importantForAccessibility="noHideDescendants">

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/veil_application_icon"
            android:layout_width="@dimen/desktop_mode_resize_veil_icon_size"
            android:layout_height="@dimen/desktop_mode_resize_veil_icon_size"
            android:layout_gravity="center"
            />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/circular_progress_indicator"
            style="@style/Widget.Material3Expressive.CircularProgressIndicator.Wavy"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="true"
            app:wavelength="20dp"
            app:indicatorSize="120dp" />
    </FrameLayout>

    <TextView
        android:id="@+id/package_update_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="@color/materialColorOnSurface"
        android:textSize="16sp"
        android:lineSpacingExtra="8sp"
        android:text="@string/package_update_text" />
</LinearLayout>
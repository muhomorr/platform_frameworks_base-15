<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="android.nativeservice.test">
    <uses-sdk android:minSdkVersion="36" android:targetSdkVersion="36" />
    <application>
        <uses-library android:name="android.test.runner" />
        <service android:name=".NativeService"
            android:exported="false"
            android:process=":NTS_native_process"
            android:nativeService="true"
            android:isolatedProcess="true">
          <property android:name="android.app.PROPERTY_NATIVE_SERVICE_LIB_NAME"
                     android:value="libsamplenativeservicetest.so" />
          <property android:name="android.app.PROPERTY_NATIVE_SERVICE_FUNC_NAME"
                     android:value="native_service_createService" />
        </service>
    </application>

    <instrumentation
        android:name="androidx.test.runner.AndroidJUnitRunner"
        android:targetPackage="android.nativeservice.test"
        android:label="Integration tests for Native Zygote" />

</manifest>


package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

aidl_interface {
    name: "sample_native_service_aidl_interface",
    unstable: true,
    visibility: [
        "//system/tools/aidl/build",
    ],
    backend: {
        java: {
            platform_apis: false,
        },
        ndk: {
            enabled: true,
        },
    },
    srcs: [
        "lib/aidl/**/*.aidl",
    ],
    local_include_dir: "lib/aidl",
}

cc_library_shared {
    name: "libsamplenativeservicetest",
    srcs: [
        "lib/NativeService.cpp",
    ],
    cflags: [
        "-Wall",
        "-Werror",
        "-Wno-missing-field-initializers",
        "-Wno-unused-variable",
    ],
    shared_libs: [
        "liblog",
        "libandroid",
        "libbinder_ndk",
    ],
    header_libs: [
        "libandroid_headers_private",
        "liblog_headers",
    ],
    static_libs: [
        "sample_native_service_aidl_interface-ndk",
    ],
    cpp_std: "c++20",
}

android_test {
    name: "NativeZygoteIntegrationTest",
    team: "trendy_team_system_performance",
    dex_preopt: {
        enabled: false,
    },
    optimize: {
        enabled: false,
    },
    static_libs: [
        "am_flags_lib",
        "android.os.flags-aconfig-java",
        "compatibility-device-util-axt",
        "sample_native_service_aidl_interface-java",
    ],
    libs: [
        "android.test.runner.stubs.test",
        "android.test.base.stubs.test",
        "mockito",
    ],
    srcs: ["src/**/*.java"],
    test_suites: [
        "general-tests",
    ],
    jni_libs: [
        "libsamplenativeservicetest",
    ],
    manifest: "AndroidManifest.xml",
    use_embedded_native_libs: true,
}

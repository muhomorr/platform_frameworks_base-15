package {
    // See: http://go/android-license-faq
    default_applicable_licenses: ["frameworks_base_license"],
}

cc_binary {
    name: "gpu_counter_producer",

    srcs: ["main.cpp"],

    shared_libs: [
        "libbase",
        "libdl",
        "liblog",
    ],

    cflags: [
        "-Wall",
        "-Werror",
        "-Wunused",
        "-Wunreachable-code",
    ],
}

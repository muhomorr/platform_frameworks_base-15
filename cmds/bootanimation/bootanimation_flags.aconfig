package: "com.android.graphics.bootanimation.flags"
container: "system"

flag {
  name: "multidisplay"
  namespace: "bootanimation"
  description: "Enable boot animation on multiple displays (e.g. foldables)"
  bug: "335406617"
  is_fixed_read_only: true
}

flag {
  name: "rgb565"
  namespace: "bootanimation"
  description: "Enable boot animation images to be decoded to RGB565"
  bug: "443909249"
  is_fixed_read_only: true
}


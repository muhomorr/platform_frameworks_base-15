// The libraries listed in ravenwood-runtime.* should be in sync with
// texts/ravenwood-classpath.txt.
// ravenwood-classpath.txt determines the order of the jar files in the classpath.

filegroup {
    name: "ravenwood-core-data",
    device_common_srcs: [
        "texts/ravenwood-build.prop",
        "texts/ravenwood-classpath.txt",
    ],
    visibility: ["//visibility:private"],
}

android_ravenwood_libgroup {
    name: "ravenwood-runtime.ravenwood-core",
    data: [
        {
            path: "ravenwood-data",
            srcs: [":ravenwood-core-data"],
        },
    ],
    libs: [
        "hoststubgen-helper-runtime",
        "ravenwood-framework",
        "ravenwood-junit-impl",
    ],
    jni_libs: [
        // Libraries has to be loaded in the following order
        "libravenwood_initializer",
        "libravenwood_runtime",
    ],
    // Install it along with "ravenwood-runtime".
    install_name: "ravenwood-runtime",
}

android_ravenwood_libgroup {
    name: "ravenwood-runtime.framework-minus-apex",
    libs: [
        "framework-minus-apex.ravenwood",
    ],
    // Install it along with "ravenwood-runtime".
    install_name: "ravenwood-runtime",
}

android_ravenwood_libgroup {
    name: "ravenwood-runtime.services.core",
    libs: [
        "services.core.ravenwood-jarjar",
    ],
    // Install it along with "ravenwood-runtime".
    install_name: "ravenwood-runtime",
}

android_ravenwood_libgroup {
    name: "ravenwood-runtime.framework-updatable",
    libs: [
        "framework-updatable.ravenwood",
    ],
    // Install it along with "ravenwood-runtime".
    install_name: "ravenwood-runtime",
}

android_ravenwood_libgroup {
    name: "ravenwood-runtime",
    data: [
        {
            path: "ravenwood-data",
            srcs: [":ravenwood-data"],
        },
        {
            path: "fonts",
            srcs: [":ravenwood-fonts"],
        },
        {
            path: "hyph-data",
            srcs: [":hyph-data"],
        },
    ],
    subruntimes: [
        "ravenwood-runtime.ravenwood-core",
        "ravenwood-runtime.framework-minus-apex",
        "ravenwood-runtime.framework-updatable",
        "ravenwood-runtime.services.core",
    ],
    libs: [
        "kxml2-android",
        "json-prebuilt",
        "ext-ravenwood",
        "icu4j-icudata-jarjar",
        "icu4j-icutzdata-jarjar",
        "mockito-ravenwood-prebuilt",
        "framework-updatable-stubs-module_libs_api-for-host",
        "all-modules-system-stubs-for-host",
    ],
}

android_ravenwood_libgroup {
    name: "ravenwood-utils",
    libs: [
        "junit",
        "mockito-ravenwood-prebuilt",
        "ravenwood-framework",
        "ravenwood-junit",
    ],
}

// Phony target to build all the Ravenwood specific artifacts:
// - ravenwood-runtime
// - ravenwood-utils
// - ravenizer
// - and their dependencies such as hoststubgen
// This allows projects like go/sonata to easily build all the

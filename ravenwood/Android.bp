package {
    // See: http://go/android-license-faq
    // A large-scale-change added 'default_applicable_licenses' to import
    // all of the 'license_kinds' from "frameworks_base_license"
    // to get the below license kinds:
    //   SPDX-license-identifier-Apache-2.0
    default_applicable_licenses: ["frameworks_base_license"],

    // OWNER: g/ravenwood
    // Bug component: 25698
    default_team: "trendy_team_ravenwood",
}

filegroup {
    name: "ravenwood-common-policies",
    srcs: [
        "texts/ravenwood-common-policies.txt",
    ],
    visibility: [":__subpackages__"],
}

filegroup {
    name: "ravenwood-aidl-policies",
    srcs: [
        "texts/ravenwood-aidl-policies.txt",
    ],
    visibility: [":__subpackages__"],
}

filegroup {
    name: "ravenwood-services-policies",
    srcs: [
        "texts/ravenwood-services-policies.txt",
    ],
    visibility: ["//visibility:private"],
}

filegroup {
    name: "ravenwood-framework-policies",
    srcs: [
        "texts/ravenwood-framework-policies.txt",
    ],
    visibility: ["//visibility:private"],
}

filegroup {
    name: "ravenwood-standard-options",
    srcs: [
        "texts/ravenwood-standard-options.txt",
    ],
    visibility: ["//visibility:private"],
}

filegroup {
    name: "ravenwood-common-options",
    srcs: [
        "texts/ravenwood-common-options.txt",
    ],
    visibility: [":__subpackages__"],
}

filegroup {
    name: "ravenizer-standard-options",
    srcs: [
        "texts/ravenizer-standard-options.txt",
    ],
    visibility: [":__subpackages__"],
}

filegroup {
    name: "ravenwood-annotation-allowed-classes",
    srcs: [
        "texts/ravenwood-annotation-allowed-classes.txt",
    ],
    visibility: ["//visibility:private"],
}

filegroup {
    name: "ravenwood-services-rename-policies",
    srcs: ["texts/ravenwood-services-rename-policies.txt"],
    visibility: ["//visibility:private"],
}

filegroup {
    name: "ravenwood-module-utils-jarjar-rules",
    srcs: ["texts/ravenwood-module-utils-jarjar-rules.txt"],
    visibility: ["//visibility:private"],
}

filegroup {
    name: "ravenwood-all-text-files",
    srcs: [
        "texts/*",
    ],
    visibility: [":__subpackages__"],
}

filegroup {
    name: "ravenwood-all-scripts",
    srcs: [
        "scripts/*",
    ],
    visibility: [":__subpackages__"],
}

// Common code that is shared across host and device.
java_library {
    name: "ravenwood-common-utils",
    host_supported: true,
    sdk_version: "core_current",
    srcs: ["common-src/**/*.java"],
    static_libs: ["modules-utils-ravenwood"],
    libs: [
        "junit",
        "framework-annotations-lib",
    ],
    visibility: ["//visibility:private"],
    jarjar_rules: ":ravenwood-module-utils-jarjar-rules",
}

// libcore-fake should be explicitly built against the host JDK, so use java_library_host.
java_library_host {
    name: "ravenwood-libcore.host",
    srcs: ["libcore-fake/**/*.java"],
    libs: [
        "app-compat-annotations",
        "framework-annotations-lib",
        "ravenwood-common-utils",
    ],
    visibility: ["//visibility:private"],
}

java_host_for_device {
    name: "ravenwood-libcore",
    libs: ["ravenwood-libcore.host"],
    visibility: ["//visibility:private"],
}

// We use java_import to ignore sdk_version of libraries, e.g. AndroidX.
// This allows us to build ravenwood-junit-impl with core_current.
java_import {
    name: "ravenwood-deps",
    jars: [
        ":androidx.test.runner",
        // Adds android.os.ext.SdkExtensions
        ":framework-sdkextensions.impl{.jar}",
        // Adds android.test.mock classes
        ":android.test.mock.impl{.jar}",
        // Adds android.test classes
        ":android.test.legacy{.jar}",
        // Adds android.testing classes
        ":testable-framework-libs{.jar}",
    ],
    visibility: ["//visibility:private"],
}

java_library {
    name: "ravenwood-junit-impl",
    srcs: [
        ":framework-configinfrastructure-ravenwood-sources",
        ":framework-ravenwood-sources",
        ":services.fakes-sources",
        "junit-impl-src/**/*.java",
        "junit-src/**/*.java",
    ],
    static_libs: [
        "ravenwood-deps",
        "ravenwood-common-utils",
        "ravenwood-libcore",
        "ow2-asm",
        "ow2-asm-analysis",
        "ow2-asm-commons",
        "ow2-asm-tree",
        "ow2-asm-util",
    ],
    libs: [
        "framework-minus-apex.ravenwood",
        "framework-updatable.ravenwood",
        "hoststubgen-helper-runtime",
        "ravenwood-framework",
        "services.core.ravenwood",
        "objenesis",
        "mockito-ravenwood-prebuilt",
    ],
    sdk_version: "core_current",
    visibility: [":__subpackages__"],
    jarjar_rules: "texts/ravenwood-runtime-jarjar-rules.txt",
}

java_device_for_host {
    name: "ravenwood-junit-for-ravenizer",
    libs: [
        "ravenwood-junit",
    ],
    visibility: [":__subpackages__"],
}

// The "impl" library above is what ships inside the Ravenwood environment to actually drive any
// API access to implementation details.
java_library {
    name: "ravenwood-junit",
    srcs: [
        "junit-src/**/*.java",
        "junit-stub-src/**/*.java",
    ],
    sdk_version: "core_current",
    static_libs: ["ravenwood-common-utils"],
    libs: [
        "ravenwood-deps",
        "framework-minus-apex.ravenwood",
        "junit",
    ],
    visibility: ["//visibility:public"],
}

// Library used to publish a handful of `android.ravenwood` APIs into
// the Ravenwood BCP; we don't want to publish these APIs into the BCP
// on physical devices, which is why this is a separate library
java_library {
    name: "ravenwood-framework",
    srcs: [
        "framework-src/**/*.java",
    ],
    libs: [
        "framework-minus-apex.ravenwood",
    ],
    sdk_version: "core_current",
    visibility: ["//visibility:public"],
}

cc_defaults {
    name: "ravenwood_jni_defaults",
    cflags: [
        "-Wall",
        "-Werror",
        "-Wno-unused-parameter",
        "-Wthread-safety",
    ],
    static_libs: [
        "libnativehelper_jvm",
    ],
    shared_libs: [
        "liblog",
    ],
    visibility: ["//visibility:private"],
}

// We need this as a separate library because we need to overload the
// sysprop symbols before libbase is loaded into the process
cc_library_host_shared {
    name: "libravenwood_initializer",
    defaults: ["ravenwood_jni_defaults"],
    srcs: ["runtime-jni/ravenwood_initializer.cpp"],
}

cc_library_host_shared {
    name: "libravenwood_runtime",
    defaults: ["ravenwood_jni_defaults"],
    header_libs: ["libicuuc_headers"],
    cflags: [
        "-DNATIVE_HELPER_EMULATE_ART_UTF_CHARS=1",
    ],
    srcs: [
        "runtime-jni/ravenwood_os_constants.cpp",
        "runtime-jni/ravenwood_runtime.cpp",
    ],
    shared_libs: [
        "libbase",
        "libcutils",
        "libutils",
        "libandroid_runtime_ravenwood",
    ],
}

// For collecting the *stats.csv files in a known directory under out/host/linux-x86/testcases/.
// The "test" just shows the available stats filenames.
sh_test_host {
    name: "ravenwood-stats-checker",
    src: "scripts/ravenwood-stats-checker.sh",
    test_suites: ["general-tests"],
    device_common_data: [
        ":framework-minus-apex.ravenwood-stats{hoststubgen_framework-minus-apex_apis.csv}",
        ":framework-minus-apex.ravenwood-stats{hoststubgen_framework-minus-apex_dump.txt}",
        ":framework-minus-apex.ravenwood-stats{hoststubgen_framework-minus-apex_keep_all.txt}",

        ":services.core.ravenwood-stats{hoststubgen_services.core_apis.csv}",
        ":services.core.ravenwood-stats{hoststubgen_services.core_dump.txt}",
        ":services.core.ravenwood-stats{hoststubgen_services.core_keep_all.txt}",

        ":framework-updatable.ravenwood-stats{hoststubgen_framework-updatable_apis.csv}",
        ":framework-updatable.ravenwood-stats{hoststubgen_framework-updatable_dump.txt}",
        ":framework-updatable.ravenwood-stats{hoststubgen_framework-updatable_keep_all.txt}",
    ],
}

// On Ravenwood, we now use Mockito 5 throughout.
// Mockito 5 doesn't have an "inline-*" module, which only contained a "marker" file
// which would signal Mockito 4 used inline-mockito.
// Mockito 5 uses the "inline" strategy by default, so we no longer need an "inline"
// module.
java_import {
    name: "mockito-ravenwood-prebuilt",
    jars: [":mockito5-hostside-prebuilt"],
    sdk_version: "core_current",
}

// We define our own version of platform_compat_config's here, because:
// - The original version (e.g. "framework-platform-compat-config) is built from
//   the output file of the device side jar, rather than the host jar, meaning
//   they're slow to build because they depend on D8/R8 output.
// - The original services one ("services-platform-compat-config") is built from services.jar,
//   which includes service.permission, which is very slow to rebuild because of kotlin.
//
// Because we're re-defining the same compat-IDs that are defined elsewhere,
// they should all have `include_in_merged_xml: false`. Otherwise, generating
// merged_compat_config.xml would fail due to duplicate IDs.
//
// These module names must end with "compat-config" because these will be used as the filename,
// and at runtime, we only loads files that match `*compat-config.xml`.
platform_compat_config {
    name: "ravenwood-framework-platform-compat-config",
    src: ":framework-minus-apex-for-host",
    include_in_merged_xml: false,
    visibility: ["//visibility:private"],
}

platform_compat_config {
    name: "ravenwood-services.core-platform-compat-config",
    src: ":services.core-for-host",
    include_in_merged_xml: false,
    visibility: ["//visibility:private"],
}

java_library {
    name: "ext-ravenwood",
    installable: false,
    static_libs: ["ext"],
    visibility: ["//visibility:private"],
}

filegroup {
    name: "ravenwood-data",
    device_common_srcs: [
        ":framework-res",
        ":ravenwood-empty-res",
        ":ravenwood-framework-platform-compat-config",
        ":ravenwood-services.core-platform-compat-config",
        ":system-build.prop",
    ],
    device_first_srcs: [
        ":apex_icu.dat",
    ],
    visibility: ["//visibility:private"],
}


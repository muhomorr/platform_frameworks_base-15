package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

java_defaults {
    name: "OverlayFlaggingTests_defaults",
    sdk_version: "current",
    srcs: ["src/**/*.kt"],
    manifest: "AndroidManifest.xml",
    libs: [
        "android.test.runner.stubs.system",
        "android.test.base.stubs.system",
    ],
    static_libs: [
        "android.content.res.flags-aconfig-java",
        "androidx.test.espresso.core",
        "androidx.test.ext.junit",
        "androidx.test.runner",
        "androidx.test.rules",
        "compatibility-device-util-axt",
        "ctstestrunner-axt",
        "flag-junit",
        "mockito-target-minus-junit4",
        "truth",
    ],
}

android_test {
    name: "OverlayFlaggingTests_TargetAppWithOverlayableXml",
    defaults: ["OverlayFlaggingTests_defaults"],
    aaptflags: [
        "--rename-manifest-package",
        "com.android.resources.targetappwithoverlayablexml",
        "--rename-resources-package",
        "com.android.resources.targetappwithoverlayablexml",
        "--rename-instrumentation-target-package",
        "com.android.resources.targetappwithoverlayablexml",
        "--custom-package",
        "com.android.resources.targetapp",
    ],
    resource_dirs: [
        "res",
        "res-overlayable",
    ],
}

android_test {
    name: "OverlayFlaggingTests_TargetAppWithoutOverlayableXml",
    defaults: ["OverlayFlaggingTests_defaults"],
    aaptflags: [
        "--rename-manifest-package",
        "com.android.resources.targetappwithoutoverlayablexml",
        "--rename-resources-package",
        "com.android.resources.targetappwithoutoverlayablexml",
        "--rename-instrumentation-target-package",
        "com.android.resources.targetappwithoutoverlayablexml",
        "--custom-package",
        "com.android.resources.targetapp",
    ],
    resource_dirs: [
        "res",
    ],
}

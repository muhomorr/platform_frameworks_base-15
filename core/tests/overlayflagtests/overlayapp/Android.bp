package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

android_app {
    name: "OverlayFlaggingTests_OverlayAppWithOverlayableXml",
    sdk_version: "current",
    manifest: "AndroidManifest.xml",
    package_name: "com.android.resources.overlayappforoverlayablexml",
    resource_dirs: ["res"],
    flags_packages: [
        "android.content.res.flags-aconfig",
    ],
}

android_app {
    name: "OverlayFlaggingTests_OverlayAppWithoutOverlayableXml",
    sdk_version: "current",
    manifest: "AndroidManifest-withoutOverlayable.xml",
    package_name: "com.android.resources.overlayappwithoutoverlayablexml",
    resource_dirs: ["res"],
    flags_packages: [
        "android.content.res.flags-aconfig",
    ],
}

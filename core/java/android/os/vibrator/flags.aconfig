package: "android.os.vibrator"
container: "system"

flag {
    namespace: "haptics"
    name: "vibration_attribute_ime_usage_api"
    is_exported: true
    description: "A public API for IME usage vibration attribute"
    bug: "304262887"
    metadata {
        purpose: PURPOSE_FEATURE
    }
}

flag {
    namespace: "haptics"
    name: "normalized_pwle_effects"
    is_exported: true
    description: "Enables functionality to create PWLE effects using advanced and simple APIs"
    bug: "341052318"
    metadata {
        purpose: PURPOSE_FEATURE
    }
}

flag {
    namespace: "haptics"
    name: "remove_hidl_support"
    description: "Remove framework code to support HIDL vibrator HALs."
    bug: "442504716"
    is_fixed_read_only: true
    metadata {
      purpose: PURPOSE_FEATURE
    }
}

flag {
    namespace: "haptics"
    name: "haptic_feedback_with_custom_usage"
    description: "API to play haptic feedback with custom usage types."
    bug: "408393305"
    is_exported: true
    metadata {
      purpose: PURPOSE_FEATURE
    }
}

flag {
    namespace: "haptics"
    name: "haptic_pcm_generation"
    description: "Enables the feature to generate Haptic PCM from vibration effects"
    bug: "417649629"
    is_exported: true
    metadata {
      purpose: PURPOSE_FEATURE
    }
}

flag {
    namespace: "haptics"
    name: "composition_pwle_apis"
    description: "Enabled public APIs to support composition of PWLE effects and primitives"
    bug: "442507169"
    metadata {
        purpose: PURPOSE_FEATURE
    }
}

flag {
    namespace: "haptics"
    name: "enable_trusted_callers"
    description: "Allows trusted system components to trigger vibrations without the VIBRATE permission."
    bug: "461931133"
    metadata {
        purpose: PURPOSE_FEATURE
    }
}

flag {
    namespace: "haptics"
    name: "composition_api"
    description: "Provides comprehensive composition API for vibration effects."
    bug: "469962388"
    metadata {
        purpose: PURPOSE_FEATURE
    }
}

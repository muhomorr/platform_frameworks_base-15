package: "android.content.res"
container: "system"

flag {
    name: "default_locale"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for default locale in LocaleConfig"
    bug: "117306409"
    # fixed_read_only or device wont boot because of permission issues accessing flags during boot
    is_fixed_read_only: true
}

flag {
    name: "font_scale_converter_public"
    is_exported: true
    namespace: "accessibility"
    description: "Enables the public API for FontScaleConverter, including enabling thread-safe caching."
    bug: "239736383"
    # fixed_read_only or device wont boot because of permission issues accessing flags during boot
    is_fixed_read_only: true
}

flag {
    name: "asset_file_descriptor_frro"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for passing in an AssetFileDescriptor to create an frro"
    bug: "304478666"
}

flag {
    name: "manifest_flagging"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for flagging manifest entries"
    bug: "297373084"
    # This flag is read in PackageParser at boot time, and in aapt2 which is a build tool.
    is_fixed_read_only: true
}

flag {
    name: "nine_patch_frro"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for creating an frro from a 9-patch"
    bug: "296324826"
}

flag {
    name: "register_resource_paths"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for register resource paths for shared library"
    bug: "306202569"
    # This flag is read in ResourcesImpl at boot time.
    is_fixed_read_only: true
}

flag {
    name: "handle_all_config_changes"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for allowing activities to handle all kinds of configuration changes"
    bug: "180625460"
    # This flag is read at boot time.
    is_fixed_read_only: true
}

flag {
    name: "dimension_frro"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for passing a dimension to create an frro"
    bug: "369672322"
}

flag {
    name: "rro_constraints"
    is_exported: false
    namespace: "resource_manager"
    description: "Feature flag for setting constraints for a RRO"
    bug: "371801644"
}

flag {
    name: "rro_control_for_android_no_overlayable"
    is_exported: true
    namespace: "resource_manager"
    description: "Allow enabling and disabling RROs targeting android package with no overlayable"
    bug: "364035303"
}

flag {
    name: "system_context_handle_app_info_changed"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for allowing system context to handle application info changes"
    bug: "362420029"
    # This flag is read at boot time.
    is_fixed_read_only: true
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "layout_readwrite_flags"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for allowing read/write flags in layout files"
    bug: "377974898"
    # This flag is used to control aapt2 behavior.
    is_fixed_read_only: true
}

flag {
    name: "resource_readwrite_flags"
    is_exported: false
    namespace: "resource_manager"
    description: "Feature flag for allowing read/write flags on individual resources"
    bug: "420720496"
    is_fixed_read_only: true
}

flag {
    name: "bag_readwrite_flags"
    is_exported: false
    namespace: "resource_manager"
    description: "Feature flag for allowing read/write flags on bag items"
    bug: "452682378"
}

flag {
    name: "resources_minor_version_support"
    is_exported: true
    namespace: "resource_manager"
    description: "Feature flag for supporting minor version in Resources"
    bug: "383177182"
    is_fixed_read_only: true
}

flag {
    name: "self_targeting_android_resource_frro"
    is_exported: true
    namespace: "customization_picker"
    description: "Fixes bug in Launcher preview by enabling overlays targeting 'android'"
    bug: "377545987"
}

flag {
    name: "always_false"
    is_exported: true
    namespace: "resource_manager"
    description: "flag always meant to be false, for testing resource flagging within cts tests"
    bug: "377974898"
}

flag {
    name: "test_flag_1"
    namespace: "resource_manager"
    description: "flag for cts tests that can be changed at runtime"
    bug: "420720496"
}

flag {
    name: "test_flag_2"
    namespace: "resource_manager"
    description: "flag for cts tests that can be changed at runtime"
    bug: "420720496"
}

flag {
    name: "test_flag_3"
    namespace: "resource_manager"
    description: "flag for cts tests that can be changed at runtime"
    bug: "420720496"
}

flag {
    name: "use_new_aconfig_storage"
    is_exported: true
    namespace: "resource_manager"
    description: "Retrieve flag values from new Aconfig flag storage in AconfigFlags.java"
    bug: "352348353"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "enhanced_debugging"
    namespace: "resource_manager"
    description: "Enable the enhanced debugging features via ProtoLog"
    bug: "416380441"
}

flag {
    name: "idmap_crc_is_mtime"
    namespace: "resource_manager"
    description: "Replace the raw crc with mtime in idmap files"
    bug: "422474410"
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "merge_idmap_binder_transactions"
    namespace: "resource_manager"
    description: "Merge per-package idmap verification and creation steps into a single binder transaction"
    bug: "422474410"
}

flag {
    name: "xml_file_size_limit"
    namespace: "resource_manager"
    description: "Only allow reading xml resources under the set size limit"
    bug: "443273051"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "generate_external_resource_idmaps"
    namespace: "resource_manager"
    description: "Generate and use idmaps for external resources referenced in APKs"
    bug: "373535266"
}

flag {
    name: "apply_font_weight_adjustment_on_cached_strings"
    namespace: "resource_manager"
    description: "Apply font weight adjustments on cached spannables if the weight has changed between caching and retrieving"
    bug: "379962518"
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "update_ams_service_appinfo"
    namespace: "resource_manager"
    description: "Update the application info object in AMS service records"
    bug: "414686685"
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

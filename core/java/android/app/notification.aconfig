package: "android.app"
container: "system"

# Note: When adding a new flag here, consider including the word "notification(s)" in the flag name
# when appropriate, as it's not currently part of the namespace so it may not be obvious what the
# flag relates to.


flag {
  name: "notifications_redesign_themed_app_icons"
  namespace: "systemui"
  description: "Notifications Redesign: Experiment to make app icons in notifications themed"
  bug: "371174789"
}

flag {
  name: "headline_prototypes"
  namespace: "notifications"
  description: "This flag adds static control for enabling prototypes for the headline project"
  bug: "449676256"
}

flag {
  name: "api_metric_style"
  is_exported: true
  namespace: "notifications"
  description: "This flag adds a new Notification.MetricStyle"
  bug: "415827681"
}

flag {
  name: "metric_value_alternative_strings"
  namespace: "notifications"
  description: "Produce different versions of the string representation of a MetricValue (e.g. 10000 -> 10,000, 10k) and choose the most appropriate for display."
  bug: "415827681"
  metadata {
    purpose: PURPOSE_BUGFIX
  }
}

flag {
  name: "api_notification_action_custom"
  is_exported: true
  namespace: "notifications"
  description: "Adds APIs to control Notification Action emphasis and style (for RONs). Also shows RON actions as pill buttons."
  bug: "440125908"
}

flag {
  name: "api_notification_semantic_style"
  is_exported: true
  namespace: "notifications"
  description: "Adds APIs to apply semantic style (color) to notification components"
  bug: "440125908"
}

flag {
  name: "api_notification_chip"
  is_exported: true
  namespace: "notifications"
  description: "Adds Notification.CompactContent and related classes. Mostly dependent on api_metric_style."
  bug: "444195983"
}

flag {
  name: "modes_ui_dnd_tile"
  namespace: "systemui"
  description: "Shows a dedicated tile for the DND mode; dependent on modes_ui"
  bug: "401217520"
  metadata {
    purpose: PURPOSE_BUGFIX
  }
}

flag {
  name: "notification_expansion_optional"
  namespace: "systemui"
  description: "Experiment to restore the pre-S behavior where standard notifications are not expandable unless they have actions."
  bug: "339523906"
}

flag {
  name: "remove_remote_views"
  namespace: "systemui"
  description: "Removes all custom views"
  bug: "342602960"
}

flag {
  name: "backup_restore_logging"
  namespace: "systemui"
  description: "Adds logging for notification/modes backup and restore events"
  bug: "289524803"
}

flag {
  name: "nm_collapsed_lines"
  namespace: "systemui"
  description: "Shows 2 lines for collapsed notifications by default"
  bug: "390217880"
  metadata {
    purpose: PURPOSE_BUGFIX
  }
}

flag {
  name: "notification_transparent_badge_ring"
  namespace: "systemui"
  description: "Makes notification badge ring transparent and skips no longer necessary method."
  bug: "409346132"
  metadata {
    purpose: PURPOSE_BUGFIX
  }
}

flag {
  name: "notification_animated_action_content_description"
  namespace: "systemui"
  description: "This flag enables the customized content description for animated actions and replies."
  bug: "412288906"
  metadata {
    purpose: PURPOSE_BUGFIX
  }
}

flag {
  name: "modes_auto_reply_message"
  namespace: "systemui"
  description: "When enabled, auto reply messages for a specific mode when it is turned on."
  bug: "467758845"
}

flag {
  name: "enable_action_attribution"
  namespace: "ailabs"
  description: "This flag enables the attribution in notification action."
  bug: "466466234"
}

flag {
  name: "automation_gi_treatment_enabled"
  namespace: "notifications"
  description: "Whether gi automation visual treatment is enabled for notifications."
  bug: "483447802"
  metadata {
    purpose: PURPOSE_FEATURE
  }
}

# Start: exported flags that cannot be removed

flag {
  name: "nm_summarization"
  namespace: "systemui"
  description: "Allows the NAS to summarize notifications"
  bug: "390417189"
  is_exported: true
}

flag {
  name: "opt_in_rich_ongoing"
  namespace: "systemui"
  is_exported: true
  description: "[RONs] v0.2 promotion logic: explicit opt-in and no colorization"
  bug: "410621769"
}

flag {
  name: "notification_channel_vibration_effect_api"
  is_exported: true
  namespace: "systemui"
  description: "This flag enables the API to allow setting VibrationEffect for NotificationChannels"
  bug: "241732519"
}

flag {
  name: "modes_api"
  is_exported: true
  namespace: "systemui"
  description: "This flag controls new and updated DND apis"
  bug: "300477976"
}

flag {
  name: "api_tvextender"
  is_exported: true
  namespace: "systemui"
  description: "Guards new android.app.Notification.TvExtender api"
  bug: "308164892"
  is_fixed_read_only: true
}

flag {
  name: "lifetime_extension_refactor"
  is_exported: true
  namespace: "systemui"
  description: "Enables moving notification lifetime extension management from SystemUI to "
      "Notification Manager Service"
  bug: "299448097"
}

flag {
  name: "category_voicemail"
  is_exported: true
  namespace: "wear_sysui"
  description: "Adds a new voicemail category for notifications"
  bug: "322806700"
}

flag {
  name: "api_rich_ongoing"
  is_exported: true
  namespace: "systemui"
  description: "[RONs] Guards new RON-related APIs, including Notification.ProgressStyle"
  bug: "337261753"
}

flag {
  name: "api_rich_ongoing_permission"
  namespace: "systemui"
  description: "[RONs] Guards new Q4 permission for RONs API"
  bug: "337261753"
  is_exported: true
}

flag {
  name: "rich_ongoing_improvements"
  namespace: "systemui"
  description: "[RONs] Visual Improvements for Live Updates, for glanceability"
  bug: "440125908"
}

flag {
  name: "nm_remove_must_have_flags"
  namespace: "notifications"
  description: "This controls the removal of the internal method parameter 'mustHaveFlags' which was used inconsistently"
  bug: "440125528"
  metadata {
    purpose: PURPOSE_BUGFIX
  }
}

flag {
  name: "hide_status_bar_notification"
  namespace: "systemui"
  description: "Allows an application running a foreground service to hide the notification icon from the status bar"
  bug: "416192314"
  is_exported: true
}

flag {
  name: "notification_is_animated_action_api"
  namespace: "systemui"
  description: "This flag enables the API to define if an action requires special visual treatment."
  bug: "417509471"
  metadata {
    purpose: PURPOSE_FEATURE
  }
  is_exported: true
}

flag {
  name: "nm_summarization_all"
  namespace: "notifications"
  is_exported: true
  description: "Allows the NAS to summarize notifications of any type"
  bug: "430487852"
}

flag {
  name: "nm_highlights"
  namespace: "notifications"
  description: "Allows the NAS to highlight notifications"
  bug: "438704838"
}

flag {
  name: "nm_insights"
  namespace: "notifications"
  description: "Shows insights derived from notifications"
  bug: "438705144"
}

flag {
  name: "nm_contextual_display"
  namespace: "notifications"
  is_exported: true
  description: "Changes notification appearance based on user created rules, prototyping"
  bug: "438704204"
}

flag {
  name: "nm_contextual_display_launch"
  namespace: "notifications"
  is_exported: true
  description: "Changes notification appearance based on user created rules"
  bug: "438704204"
}

flag {
   name: "bridged_notifications"
   is_exported: true
   namespace: "notifications"
   description: "Adds support for specifying bridged notification metadata for displaying to the user."
   bug: "438827600"
}

flag {
  name: "notification_semantic_actions_for_playback"
  namespace: "notifications"
  description: "Adds semantic action values for PLAY/PAUSE/STOP"
  is_exported: true
  bug: "458744035"
}

flag {
  name: "api_projected_extender"
  namespace: "notifications"
  description: "Guards new android.app.Notification.ProjectedExtender api"
  bug: "455909258"
  is_exported: true
}

flag {
  name: "prefer_small_icon"
  namespace: "notifications"
  description: "Makes prefer small icon fully public"
  bug: "469460575"
  is_exported: true
}

# End: exported flags that cannot be removed


# Start: Flags that have been cleaned up in code but need to remain for CTS

flag {
  name: "restrict_audio_attributes_call"
  namespace: "systemui"
  description: "Only CallStyle notifs can use USAGE_NOTIFICATION_RINGTONE"
  bug: "331793339"
}

flag {
  name: "restrict_audio_attributes_alarm"
  namespace: "systemui"
  description: "Only alarm category notifs can use USAGE_ALARM"
  bug: "331793339"
}

flag {
  name: "restrict_audio_attributes_media"
  namespace: "systemui"
  description: "No notifs can use USAGE_UNKNOWN or USAGE_MEDIA"
  bug: "331793339"
}

flag {
  name: "modes_ui"
  namespace: "systemui"
  description: "This flag controls new and updated DND UIs; dependent on flag modes_api"
  bug: "270703654"
}

flag {
  name: "modes_ui_transit"
  namespace: "systemui"
  description: "This flag controls DND UI: transit mode"
  is_exported: true
  bug: "450159513"
}

# End: Flags that have been cleaned up in code but need to remain for CTS

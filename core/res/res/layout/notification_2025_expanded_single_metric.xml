<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/metric_view_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="2dp"
    android:baselineAligned="false"
    android:gravity="top" >

        <TextView
            android:id="@+id/metric_label_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            style="@style/NotificationExpandedSingleMetricLabel"
            android:layout_weight="1"
            />

        <TextView
            android:id="@+id/metric_value_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/NotificationExpandedSingleMetricValue"
            android:layout_weight="1"
            />

        <Chronometer
            android:id="@+id/metric_chronometer_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            style="@style/NotificationExpandedSingleMetricValue"
            android:layout_weight="1"
            />
</LinearLayout>

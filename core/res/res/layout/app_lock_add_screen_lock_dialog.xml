<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/dialog_padding_material"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/app_lock_add_screen_lock_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/dialog_padding_material"
            android:paddingEnd="@dimen/dialog_padding_material"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/app_lock_dialog_lock_icon"
                android:layout_width="@dimen/resolver_icon_size"
                android:layout_height="@dimen/resolver_icon_size"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_lock_bold"
                android:tint="@color/materialColorPrimary" />

            <TextView
                android:id="@+id/app_lock_dialog_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/app_lock_margin_medium"
                android:layout_marginBottom="@dimen/app_lock_margin_small"
                android:text="@string/app_lock_add_screen_lock_title"
                android:textAppearance="@style/TextAppearance.DeviceDefault.AppLock.Title" />

            <TextView
                android:id="@+id/app_lock_dialog_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/app_lock_margin_small"
                android:layout_marginBottom="@dimen/app_lock_margin_large"
                android:text="@string/app_lock_add_screen_lock_message"
                android:textColor="@color/materialColorOnSurfaceVariant"
                android:textAppearance="@style/TextAppearance.DeviceDefault.AppLock.Body"
                android:textAlignment="viewStart"
                android:gravity="start" />
        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/app_lock_add_screen_lock_bottom_sheet_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="@dimen/app_lock_item_margin_small"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/app_lock_padding_extra_small"
        android:paddingStart="@dimen/dialog_padding_material"
        android:paddingEnd="@dimen/dialog_padding_material"
        android:paddingBottom="@dimen/dialog_padding_material"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <Button
            android:id="@+id/app_lock_dialog_cancel_button"
            style="@android:style/Widget.DeviceDefault.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/app_lock_btn_pill_outline"
            android:gravity="center"
            android:textAlignment="center"
            android:paddingStart="@dimen/app_lock_padding_small"
            android:paddingEnd="@dimen/app_lock_padding_small"
            android:paddingTop="@dimen/app_lock_button_padding"
            android:paddingBottom="@dimen/app_lock_button_padding"
            android:minHeight="@dimen/app_lock_edu_button_min_height"
            android:minWidth="0dp"
            android:layout_marginEnd="@dimen/dialog_title_divider_material"
            android:text="@android:string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/materialColorPrimary" />

        <Button
            android:id="@+id/app_lock_dialog_add_screen_lock_button"
            style="@android:style/Widget.DeviceDefault.Button.Colored"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/app_lock_btn_pill_background"
            android:gravity="center"
            android:textAlignment="center"
            android:paddingStart="@dimen/app_lock_padding_small"
            android:paddingEnd="@dimen/app_lock_padding_small"
            android:paddingTop="@dimen/app_lock_button_padding"
            android:paddingBottom="@dimen/app_lock_button_padding"
            android:minHeight="@dimen/app_lock_edu_button_min_height"
            android:minWidth="0dp"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="@string/app_lock_add_screen_lock_button_text"
            android:textAllCaps="false"
            android:textColor="@color/materialColorOnPrimary" />
    </LinearLayout>
</LinearLayout>

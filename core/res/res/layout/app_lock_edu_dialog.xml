<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottomsheet_expressive_background"
    android:layout_ignoreOffset="true"
    android:paddingTop="@dimen/dialog_padding_material">

    <ScrollView
        android:id="@+id/app_lock_edu_scrollview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:nestedScrollingEnabled="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="?android:attr/dialogPreferredPadding"
            android:paddingEnd="?android:attr/dialogPreferredPadding">

            <ImageView
                android:layout_width="@dimen/resolver_icon_size"
                android:layout_height="@dimen/resolver_icon_size"
                android:src="@drawable/ic_lock_bold"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@null"
                android:tint="@color/materialColorPrimary"
                android:layout_marginBottom="@dimen/app_lock_margin"/>

            <TextView
                android:id="@+id/app_lock_edu_dialog_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_lock_edu_dialog_enable_app_lock_title"
                android:textAppearance="@style/TextAppearance.DeviceDefault.AppLock.Title"
                android:lineHeight="@dimen/app_lock_line_height_large"
                android:gravity="center"
                android:textColor="@color/materialColorOnSurface"
                android:layout_marginBottom="@dimen/app_lock_margin"/>

            <TextView
                android:id="@+id/app_lock_edu_dialog_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.DeviceDefault.AppLock.Body"
                android:justificationMode="inter_word"
                android:textColor="@color/materialColorOnSurfaceVariant"
                android:layout_marginBottom="@dimen/dialog_padding_material"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_lock_edu_dialog_info_header"
                android:textAppearance="@style/TextAppearance.DeviceDefault.AppLock.InfoHeader"
                android:textColor="@color/materialColorOnSurfaceVariant"
                android:layout_marginBottom="@dimen/app_lock_margin"/>

            <LinearLayout style="@style/AppLockInfoItemStyle">

                <ImageView
                    android:layout_width="@dimen/app_lock_icon_size_small"
                    android:layout_height="@dimen/app_lock_icon_size_small"
                    android:src="@drawable/ic_notifications"
                    android:contentDescription="@null"
                    android:tint="@color/materialColorOnSurface"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_lock_edu_dialog_info_notifications"
                    android:layout_marginStart="@dimen/app_lock_item_margin"
                    android:textAppearance="@style/TextAppearance.DeviceDefault.AppLock.ItemText"
                    android:lineHeight="@dimen/app_lock_line_height_small"
                    android:textColor="@color/materialColorOnSurface"/>
            </LinearLayout>

            <LinearLayout style="@style/AppLockInfoItemStyle">

                <ImageView
                    android:layout_height="@dimen/app_lock_icon_size_small"
                    android:layout_width="@dimen/app_lock_icon_size_small"
                    android:src="@drawable/ic_widgets"
                    android:contentDescription="@null"
                    android:tint="@color/materialColorOnSurface"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_lock_edu_dialog_info_widgets"
                    android:layout_marginStart="@dimen/app_lock_item_margin"
                    android:textAppearance="@style/TextAppearance.DeviceDefault.AppLock.ItemText"
                    android:lineHeight="@dimen/app_lock_line_height_small"
                    android:textColor="@color/materialColorOnSurface"/>
            </LinearLayout>

            <LinearLayout style="@style/AppLockInfoItemStyle"
                android:layout_marginBottom="@dimen/dialog_padding_material">

                <ImageView
                    android:layout_height="@dimen/app_lock_icon_size_small"
                    android:layout_width="@dimen/app_lock_icon_size_small"
                    android:src="@drawable/ic_info_sparkle"
                    android:contentDescription="@null"
                    android:tint="@color/materialColorOnSurface"/>
                <TextView
                    android:id="@+id/app_lock_edu_dialog_info_ai_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/app_lock_item_margin"
                    android:textAppearance="@style/TextAppearance.DeviceDefault.AppLock.ItemText"
                    android:lineHeight="@dimen/app_lock_line_height_small"
                    android:textColor="@color/materialColorOnSurface"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/app_lock_edu_bottom_sheet_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="@dimen/app_lock_item_margin_small"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="?android:attr/dialogPreferredPadding"
        android:paddingEnd="?android:attr/dialogPreferredPadding"
        android:paddingTop="@dimen/app_lock_padding_extra_small"
        android:paddingBottom="@dimen/navigation_bar_height">

        <Button
            android:id="@+id/app_lock_edu_dialog_btn_lock_app"
            style="@android:style/Widget.DeviceDefault.Button.Colored"
            android:background="@drawable/app_lock_btn_pill_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/app_lock_button_padding"
            android:paddingBottom="@dimen/app_lock_button_padding"
            android:minHeight="@dimen/app_lock_edu_button_min_height"
            android:layout_marginBottom="@dimen/app_lock_margin"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="@string/app_lock_edu_dialog_button_lock"
            android:textColor="@color/materialColorOnPrimary"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/app_lock_edu_dialog_btn_cancel"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/app_lock_button_padding"
            android:paddingBottom="@dimen/app_lock_button_padding"
            android:minHeight="@dimen/app_lock_edu_button_min_height"
            android:text="@android:string/cancel"
            android:textColor="@color/materialColorPrimary"
            android:textAllCaps="false"/>
    </LinearLayout>
</LinearLayout>

}

flag {
    name: "consolidate_collect_reachable"
    namespace: "backstage_power"
    description: "Consolidate collectReachable usage to one implementation."
    bug: "364936739"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "enable_long_method_tracing_on_anr_timer"
    namespace: "stability"
    description: "Enable Long Method Tracing for ANR Timer"
    bug: "419753987"
    is_fixed_read_only: true
}

flag {
    name: "enable_activity_manager_structured_service"
    namespace: "system_performance"
    description: "Enable ActivityManagerStructured Service"
    bug: "419409018"
}

flag {
    name: "not_skip_connection_recompute_for_bind_schedule_like_top_app"

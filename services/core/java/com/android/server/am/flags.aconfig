    name: "service_check_calling_pkg"
    namespace: "backstage_power"
    description: "Throw security exception on service APIs if calling package doesn't match calling uid."
    bug: "308138385"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "enable_zram_writeback"

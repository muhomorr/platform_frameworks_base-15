    bug: "458135219"
}

flag {
    name: "rollout_pixel_faceauth"
    namespace: "core_experiments_team_internal"
    description: "Rolls out the pixel_faceauth namespace."
    bug: "436480687"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "psc_batch_service_updates"
    namespace: "backstage_power"

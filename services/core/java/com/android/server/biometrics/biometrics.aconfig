package: "com.android.server.biometrics"
container: "system"

flag {
  name: "use_vhal_for_testing"
  namespace: "biometrics_framework"
  description: "This flag controls whether virtual HAL is used for testing instead of TestHal "
  bug: "294254230"
}

flag {
  name: "hidl_service_died_fix"
  namespace: "biometrics_framework"
  description: "This bugfix flag is for setting user id and session to null when HIDL HAL service dies"
  bug: "446125611"
  metadata {
    purpose: PURPOSE_BUGFIX
  }
}

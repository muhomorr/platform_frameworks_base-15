package: "com.android.server.display.feature.flags"
container: "system"

# Important: Flags must be accessed through DisplayManagerFlags.

flag {
    name: "is_always_on_available_api"
    namespace: "display_manager"
    description: "Allows querying of AOD availability"
    bug: "324046664"
    is_fixed_read_only: true
    is_exported: true
}

flag {
    name: "enable_power_throttling_clamper"
    namespace: "display_manager"
    description: "Feature flag for Power Throttling Clamper"
    bug: "294777007"
    is_fixed_read_only: true
}

flag {
    name: "display_topology_api"
    namespace: "display_manager"
    description: "API for reading the current display topology"
    bug: "404269099"
    is_fixed_read_only: true
    is_exported: true
}

flag {
    name: "change_default_display_lid_closed"
    namespace: "display_manager"
    description: "Make one of the secondary displays the default display when the device's lid is closed"
    bug: "400351704"
}

flag {
    name: "configurable_default_doze_values"
    namespace: "display_manager"
    description: "Specify the default doze values in config.xml"
    bug: "279161929"
}

flag {
    name: "fast_hdr_transitions"
    namespace: "display_manager"
    description: "Feature flag for fast transitions into/out of HDR"
    bug: "292124102"
    is_fixed_read_only: true
}

flag {
    name: "sensor_based_brightness_throttling"
    namespace: "display_manager"
    description: "Feature flag for enabling brightness throttling using sensor from config."
    bug: "294900859"
    is_fixed_read_only: true
}

flag {
    name: "use_fusion_prox_sensor"
    namespace: "display_manager"
    description: "Feature flag to control usage of a Fusion Proximity sensor if configued."
    bug: "306203895"
    is_fixed_read_only: true
}

flag {
    name: "highest_hdr_sdr_ratio_api"
    namespace: "display_manager"
    description: "Feature flag for an API to get the highest defined HDR/SDR ratio for a display."
    bug: "335181559"
    is_fixed_read_only: true
    is_exported: true
}

flag {
    name: "normal_brightness_for_doze_parameter"
    namespace: "wear_frameworks"
    description: "Feature flag for the parameter specifying whether brightness should be adjusted while dozing."
    bug: "343283838"
    is_fixed_read_only: true
}

flag {
    name: "enable_battery_stats_for_all_displays"
    namespace: "display_manager"
    description: "Flag to enable battery stats for all displays."
    bug: "366112793"
    is_fixed_read_only: true
}

flag {
    name: "block_autobrightness_changes_on_stylus_usage"
    namespace: "display_manager"
    description: "Block the usage of ALS to control the display brightness when stylus is being used"
    bug: "352411468"
    is_fixed_read_only: true
}

flag {
    name: "enable_has_arr_support"
    namespace: "core_graphics"
    description: "Flag for an API to get whether display supports ARR or not"
    bug: "361433651"
    is_fixed_read_only: true
    is_exported: true
}

flag {
    name: "enable_get_suggested_frame_rate"
    namespace: "core_graphics"
    description: "Flag for an API to get suggested frame rates"
    bug: "361433796"
    is_fixed_read_only: true
    is_exported: true
}

flag {
    name: "display_listener_performance_improvements"
    namespace: "display_manager"
    description: "Feature flag for an API to let the apps subscribe to a specific property change of the Display."
    bug: "372700957"
    is_fixed_read_only: true
    is_exported: true
}

flag {
    name: "enable_get_supported_refresh_rates"
    namespace: "core_graphics"
    description: "Flag to use the surfaceflinger rates for getSupportedRefreshRates"
    bug: "365163968"
    is_fixed_read_only: true
    is_exported: true
}

flag {
    name: "enable_hdr_override_plugin_type"
    namespace: "display_manager"
    description: "Enable hdr override plugin type"
    bug: "389873155"
    is_fixed_read_only: true
}

flag {
    name: "enable_max_brightness_cap_override_plugin_type"
    namespace: "display_manager"
    description: "Enable max brightness cap override plugin type"
    bug: "441368631"
}

flag {
    name: "refactor_normal_brightness_mode_controller"
    namespace: "display_manager"
    description: "Integrate NormalBrightnessModeController into the brightness clamper framework."
    bug: "431176838"
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "enable_display_content_mode_management"
    namespace: "lse_desktop_experience"
    description: "Enable switching the content mode of connected displays between mirroring and extended. Also change the default content mode to extended mode."
    bug: "378385869"
}

flag {
    name: "subscribe_granular_display_events"
    namespace: "display_manager"
    description: "Enable subscription to granular display change events."
    bug: "379250634"
    is_fixed_read_only: true
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "framerate_override_triggers_rr_callbacks"
    namespace: "display_manager"
    description: "Feature flag to trigger the RR callbacks when framerate overridding happens."
    bug: "390113266"
    is_fixed_read_only: true
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "refresh_rate_event_for_foreground_apps"
    namespace: "display_manager"
    description: "Send Refresh Rate events only for the apps in foreground."
    bug: "390107600"
    is_fixed_read_only: true
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "display_category_built_in"
    namespace: "windowing_sdk"
    description: "Add a new category to get the built in displays."
    bug: "293651324"
    is_fixed_read_only: false
    is_exported: true
}

flag {
    name: "committed_state_separate_event"
    namespace: "display_manager"
    description: "Move Display committed state into a separate event"
    bug: "342192387"
    is_fixed_read_only: true
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "separate_timeouts"
    namespace: "lse_desktop_experience"
    description: "Allow separate timeouts for different power groups"
    bug: "402356291"
}

flag {
    name: "delay_implicit_rr_registration_until_rr_accessed"
    namespace: "display_manager"
    description: "Feature flag for clients to subscribe to RR changes by either explicitly subscribing for refresh rate changes or request for refresh rate data"
    bug: "391828526"
    is_fixed_read_only: true
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "enable_default_display_in_topology_switch"
    namespace: "lse_desktop_experience"
    description: "Add a switch that allows the user to include the default display in display topology. This is only used for projected mode."
    bug: "407512389"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "ensure_color_fade_when_turning_on"
    namespace: "biometrics_integration"
    description: "Ensure color fade when turing on screen"
    bug: "384986206"
    is_fixed_read_only: true
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "enable_on_display_added_in_observer"
    namespace: "display_manager"
    description: "On display added should be called after the display listener is registered."
    bug: "414778119"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "enable_logging_for_display_events"
    namespace: "display_manager"
    description: "Enable logging statistics for display event occurrences."
    bug: "433479938"
}

flag {
    name: "minmode_cap_brightness_enabled"
    namespace: "display_manager"
    description: "Restrict the brightness due to minmode"
    bug: "433557124"
    metadata {
      purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "configure_app_resolution_change"
    namespace: "display_manager"
    description: "Enables app dynamic resolution change configuration"
    bug: "414654227"
}

flag {
    name: "display_ids_cache"
    namespace: "display_manager"
    description: "Feature flag for cache of display ids in DisplayManagerGlobal"
    bug: "461159073"
}

flag {
    name: "display_ids_cache_validation"
    namespace: "display_manager"
    description: "Feature flag for validation cache of display ids in DisplayManagerGlobal"
    bug: "461159073"
}

flag {
    name: "enable_display_event_merging"
    namespace: "display_manager"
    description: "Enable merging of display events"
    bug: "378668902"
}

flag {
    name: "enable_work_durations"
    namespace: "display_manager"
    description: "Enable the propagating of work durations from config to surface flinger"
    bug: "399396620"
}

flag {
    name: "display_info_copy_on_write_cache_enabled"
    namespace: "display_manager"
    description: "Enable copy on write cache for display info"
    bug: "430010606"
    metadata {
          purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "frame_rate_mapping_api"
    namespace: "core_graphics"
    description: "Adds new api to query the frame rate / velocity mapping values"
    bug: "453060939"
    is_exported: true
}

flag {
    name: "auto_brightness_mode_charging"
    namespace: "wear_frameworks"
    description: "Feature flag for loading and applying auto-brightness curve while the device is connected to the charger."
    bug: "421103840"
}

flag {
    name: "virtual_secondary_displays"
    namespace: "lse_desktop_experience"
    description: "Enable Connected Display features on virtual displays with proper configuration"
    bug: "459987054"
}

flag {
    name: "enable_null_display_info_cache"
    namespace: "display_manager"
    description: "Enable null DisplayInfo caching in DisplayManagerGlobal so subsequent calls with null avoid a binder call."
    bug: "475776125"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

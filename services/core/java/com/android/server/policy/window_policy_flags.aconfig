package: "com.android.server.policy"
container: "system"

flag {
    name: "support_input_wakeup_delegate"
    namespace: "wear_frameworks"
    description: "Whether or not window policy allows injecting input wake-up delegate."
    bug: "319132073"
}

flag {
    name: "bug_toasts_on_top_of_bubble"
    namespace: "windowing_sdk"
    description: "Show system added toasts at same level as system error."
    bug: "409222337"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "wear_key_gesture_handling"
    namespace: "wear_frameworks"
    description: "Migrate Wear key gestures handling logic to Wear code base."
    bug: "368159846"
}

flag {
    name: "wear_keyguard_drawn_timeout_on_boot_config"
    namespace: "wear_services"
    description: "Set a timeout for keyguard drawn on boot based on the config value."
    bug: "446797835"
}

flag {
    name: "brightness_override_toast"
    namespace: "window_manager"
    description: "Show a toast when brightness is overridden by a window."
    bug: "489266560"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

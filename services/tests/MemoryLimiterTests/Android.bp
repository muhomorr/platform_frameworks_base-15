// Standalone tests for MemoryLimiter. These tests require root and disabled
// SELinux to manipulate cgroups, so they are in a separate module from
// FrameworksServicesTests.

package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

android_test {
    name: "MemoryLimiterTests",
    team: "trendy_team_system_performance",
    platform_apis: true,
    defaults: [
        "modules-utils-testable-device-config-defaults",
        "FrameworksServicesTests-jni-defaults",
    ],
    srcs: ["src/**/*.java"],
    static_libs: [
        "androidx.test.ext.junit",
        "androidx.test.ext.truth",
        "androidx.test.runner",
        "com.android.server.flags.services-aconfig-java",
        "frameworks-base-testutils",
        "flag-junit",
        "services.core",
    ],
    data: [
        ":MemoryLimiterTestApp",
    ],
    test_suites: ["device-tests"],
}

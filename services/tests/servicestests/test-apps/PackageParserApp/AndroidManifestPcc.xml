          android:authorities="com.android.servicestests.apps.packageparserapp.myproviderexplicitlynotpcc"
          android:isPrivateComputeCoreProcess="false" />
        <activity-alias android:name=".MyActivityAliasExplicitlyNotPcc" android:targetActivity=".MyActivityExplicitlyNotPcc"
          android:isPrivateComputeCoreProcess="false" />

        <service android:name=".MyService" />
        <receiver android:name=".MyReceiver" />
        <provider android:name=".MyProvider"
            android:authorities="com.android.servicestests.apps.packageparserapp.myprovider" />

    </application>
</manifest>


<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.android.servicestests.apps.packageparserapp">
    <application>
        <activity android:name=".MyActivity" />

        <activity android:name=".PccActivity" android:isPrivateComputeCoreProcess="true" />
        <service android:name=".PccService" android:isPrivateComputeCoreProcess="true" />
        <receiver android:name=".PccReceiver" android:isPrivateComputeCoreProcess="true" />
        <provider android:name=".PccProvider"
          android:authorities="com.android.servicestests.apps.packageparserapp.pccprovider"
          android:isPrivateComputeCoreProcess="true" />
        <activity-alias android:name=".PccActivityAlias" android:targetActivity=".PccActivity"
          android:isPrivateComputeCoreProcess="true" />
        <activity-alias android:name=".PccActivityAliasToNormal" android:targetActivity=".MyActivity"
          android:isPrivateComputeCoreProcess="true" />

        <activity-alias android:name=".MyActivityAliasToPcc" android:targetActivity=".PccActivity"
          android:isPrivateComputeCoreProcess="false" />

        <activity android:name=".MyActivityExplicitlyNotPcc" android:isPrivateComputeCoreProcess="false" />

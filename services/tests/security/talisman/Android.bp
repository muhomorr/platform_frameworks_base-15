package {
    // See: http://go/android-license-faq
    // A large-scale-change added 'default_applicable_licenses' to import
    // all of the 'license_kinds' from "frameworks_base_license"
    // to get the below license kinds:
    //   SPDX-license-identifier-Apache-2.0
    default_applicable_licenses: ["frameworks_base_license"],
    default_team: "trendy_team_multi_device_identity",
}

java_defaults {
    name: "talisman_tests_defaults",
    static_libs: [
        "androidx.annotation_annotation",
        "androidx.test.ext.junit",
        "androidx.test.rules",
        "androidx.test.runner",
        "testng",
        "truth",
    ],
    platform_apis: true,
    certificate: "platform",
    use_resource_processor: true,
    // Required for TestParameterInjector
    javacflags: ["-parameters"],
}

android_app {
    name: "TalismanTestStub",
    platform_apis: true,
    manifest: "configs/AndroidManifest.xml",
}

android_robolectric_test {
    name: "TalismanTestsRobolectric",
    defaults: ["talisman_tests_defaults"],
    instrumentation_for: "TalismanTestStub",
    srcs: [
        "src/**/*.java",
    ],
    static_libs: [
        "services.core",
    ],
    java_resource_dirs: ["configs/robolectric"],
    upstream: true,
    test_suites: [
        "general-tests",
        "robolectric-tests",
    ],
}

android_test {
    name: "TalismanTestsDevice",
    defaults: ["talisman_tests_defaults"],
    manifest: "configs/AndroidManifest.xml",
    test_config: "configs/AndroidTest.xml",
    srcs: [
        "src/**/*.java",
    ],
    static_libs: [
        "services.core",
    ],
    test_suites: ["general-tests"],
}

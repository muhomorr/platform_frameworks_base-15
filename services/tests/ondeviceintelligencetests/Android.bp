package {
    default_applicable_licenses: ["frameworks_base_license"],
}

java_defaults {
    name: "FrameworksOnDeviceIntelligenceTestsDefaults",
    defaults: [
        "modules-utils-testable-device-config-defaults",
    ],
    static_libs: [
        "androidx.test.core",
        "androidx.test.runner",
        "androidx.test.ext.truth",
        "mockito-target-extended-minus-junit4",
        "platform-test-annotations",
        "services.core",
        "servicestests-core-utils",
        "servicestests-utils-mockito-extended",
        "truth",
        "frameworks-base-testutils",
        "androidx.test.rules",
    ],
    libs: [
        "android.test.mock.stubs.system",
        "android.test.base.stubs.system",
        "android.test.runner.stubs.system",
    ],
    certificate: "platform",
    platform_apis: true,
    test_suites: ["device-tests"],
    optimize: {
        enabled: false,
    },
}

android_test {
    name: "FrameworksOnDeviceIntelligenceTests",
    defaults: ["FrameworksOnDeviceIntelligenceTestsDefaults"],
    team: "trendy_team_machine_learning",
    srcs: select(soong_config_variable("ANDROID", "release_ondevice_intelligence_module"), {
        "true": ["src/module/**/*.java"],
        default: ["src/platform/**/*.java"],
    }),
    static_libs: select(soong_config_variable("ANDROID", "release_ondevice_intelligence_module"), {
        "true": [
            "service-ondeviceintelligence-internal",
            "framework-ondeviceintelligence.impl",
        ],
        default: [],
    }),
}

<configuration description="Multiuser Integration Tests">
    <option name="test-suite-tag" value="apct" />
    <option name="test-suite-tag" value="apct-instrumentation" />

    <target_preparer class="com.android.tradefed.targetprep.suite.SuiteApkInstaller">
        <option name="test-file-name" value="InteractiveHsumIntegrationTests.apk" />
        <option name="cleanup-apks" value="true" />
        <option name="install-arg" value="-t --user 0" />
    </target_preparer>

    <!-- MUST switch to system as that's exactly what it tests -->
    <target_preparer class="com.android.tradefed.targetprep.SwitchUserTargetPreparer">
        <option name="user-type" value="system" />
    </target_preparer>

    <!-- Test Runner -->
    <test class="com.android.tradefed.testtype.AndroidJUnitTest" >
        <option name="package" value="android.integration.multiuser" />
        <option name="runner" value="androidx.test.runner.AndroidJUnitRunner" />
    </test>

</configuration>
